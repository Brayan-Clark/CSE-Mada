---
import ThemeToggle from './ThemeToggle.astro';
import { withBase } from '../utils/url';

const links = [
  { name: 'Accueil', href: withBase('/') },
  { name: 'Matériel', href: withBase('/materiel') },
  { name: 'Services', href: withBase('/services') },
  { name: 'Blog', href: withBase('/blog') },
  { name: 'Events', href: withBase('/events') },
  { name: 'Contact', href: withBase('/contact') },
];

const home = withBase('/').replace(/\/$/, '');
const current = Astro.url.pathname.replace(/\/$/, '') || home;

function isActive(href: string): boolean {
  const target = href.replace(/\/$/, '');
  if (target === home) return current === home;
  return current === target || current.startsWith(`${target}/`);
}
---

<header
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
>
  <div class="container w-full mx-auto px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">
    <a href={withBase('/')} class="flex items-center space-x-2 font-bold text-lg">
      <img src={withBase('/images/CSE-logo.jpg')} alt="Logo" class="w-16" />
      <span class="text-green-700">Camping Store & Event</span>
    </a>

    <nav class="hidden md:flex items-center space-x-6 justify-center">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium transition-colors py-1',
              isActive(link.href)
                ? 'text-green-700 dark:text-green-400 after:absolute after:-bottom-px after:left-0 after:h-0.5 after:w-full after:rounded-full after:bg-green-600'
                : 'text-foreground hover:text-green-700 dark:hover:text-green-400',
            ]}
          >
            {link.name}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>

    <!-- Mobile menu button -->
    <button class="md:hidden p-2" id="mobile-menu-button">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    class="md:hidden hidden border-t border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
    id="mobile-menu"
  >
    <div class="container py-4 space-y-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'block py-2 pl-3 border-l-2 transition-colors',
              isActive(link.href)
                ? 'border-green-600 text-green-700 dark:text-green-400 font-semibold bg-green-50 dark:bg-green-900/20'
                : 'border-transparent text-foreground hover:text-green-700 dark:hover:text-green-400',
            ]}
          >
            {link.name}
          </a>
        ))
      }
      <div class="pt-2 flex justify-center">
        <ThemeToggle />
      </div>
    </div>
  </div>

  <script>
    // Gestion du menu mobile
    document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
      const menu = document.getElementById('mobile-menu');
      menu?.classList.toggle('hidden');
    });
  </script>
</header>

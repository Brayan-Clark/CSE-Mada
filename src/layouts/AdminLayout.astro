---
import { withBase } from '../utils/url';
import { isSupabaseEnabled } from '../utils/supabase';
import '../styles/theme.css';

interface Props {
  title?: string;
  active?: 'dashboard' | 'articles' | 'events' | 'products' | 'orders' | 'stock' | 'services' | 'reviews' | 'messages' | 'users' | 'roles' | 'account';
}

const { title = 'Administration', active } = Astro.props;
const loginUrl = withBase('/admin/login');

const navItems = [
  { id: 'dashboard', label: 'Tableau de bord', href: withBase('/admin'), perm: null, icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { id: 'articles', label: 'Articles', href: withBase('/admin/articles'), perm: 'articles.view', icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z' },
  { id: 'events', label: 'Événements', href: withBase('/admin/events'), perm: 'events.view', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { id: 'products', label: 'Matériel', href: withBase('/admin/products'), perm: 'products.view', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
  { id: 'orders', label: 'Commandes', href: withBase('/admin/orders'), perm: 'orders.view', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { id: 'stock', label: 'Stock & achats', href: withBase('/admin/stock'), perm: 'stock.view', icon: 'M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4' },
  { id: 'services', label: 'Services', href: withBase('/admin/services'), perm: 'services.view', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { id: 'reviews', label: 'Avis', href: withBase('/admin/reviews'), perm: 'reviews.view', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
  { id: 'messages', label: 'Messages', href: withBase('/admin/messages'), perm: 'messages.view', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { id: 'users', label: 'Utilisateurs', href: withBase('/admin/users'), perm: 'users.manage', icon: 'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4z' },
  { id: 'roles', label: 'Rôles & permissions', href: withBase('/admin/roles'), perm: 'roles.manage', icon: 'M12 11c0-1.105.895-2 2-2s2 .895 2 2-.895 2-2 2m-6 4h12a2 2 0 002-2v-5a2 2 0 00-2-2H6a2 2 0 00-2 2v5a2 2 0 002 2zM8 11V7a4 4 0 118 0v4' },
  { id: 'account', label: 'Mon compte', href: withBase('/admin/account'), perm: null, icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
];
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Admin CSE</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.ico')} />
    <script is:inline define:vars={{ loginUrl }}>
      // Évite le flash de thème : applique le thème AVANT le premier rendu.
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      // Garde d'accès anticipée : si pas de session locale, on redirige tout de
      // suite (avant de peindre le contenu protégé) pour éviter le flash.
      try {
        const raw = localStorage.getItem('cse_admin_session');
        const sess = raw ? JSON.parse(raw) : null;
        const valid = sess && (!sess.expiresAt || Date.now() < sess.expiresAt);
        if (!valid) window.location.replace(loginUrl);
      } catch (_e) { /* en cas de souci, la garde du module prend le relais */ }
    </script>
    <style is:inline>
      /* Écran de chargement admin — visible tant que la page n'est pas prête. */
      #admin-loader {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
        background: #f3f4f6;
        transition: opacity .4s ease, visibility .4s ease;
      }
      :root.dark #admin-loader { background: #030712; }
      #admin-loader.is-hidden { opacity: 0; visibility: hidden; }
      .admin-loader-logo {
        display: inline-flex;
        height: 3.5rem; width: 3.5rem;
        align-items: center; justify-content: center;
        border-radius: 1rem;
        background: #16a34a; color: #fff;
        font-weight: 800; font-size: 1.5rem;
        box-shadow: 0 10px 30px -8px rgba(22,163,74,.6);
        animation: admin-pulse 1.6s ease-in-out infinite;
      }
      .admin-loader-spinner {
        height: 2rem; width: 2rem;
        border: 3px solid rgba(22,163,74,.25);
        border-top-color: #16a34a;
        border-radius: 9999px;
        animation: admin-spin .8s linear infinite;
      }
      .admin-loader-text {
        font-family: system-ui, -apple-system, sans-serif;
        font-size: .9rem; font-weight: 500;
        color: #6b7280; letter-spacing: .01em;
      }
      :root.dark .admin-loader-text { color: #9ca3af; }
      @keyframes admin-spin { to { transform: rotate(360deg); } }
      @keyframes admin-pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.08); }
      }
      @media (prefers-reduced-motion: reduce) {
        .admin-loader-logo, .admin-loader-spinner { animation: none; }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-100 dark:bg-gray-950 text-gray-900 dark:text-gray-100 antialiased">
    <!-- Écran de chargement (masqué une fois l'accès vérifié et le contenu prêt) -->
    <div id="admin-loader" role="status" aria-live="polite">
      <span class="admin-loader-logo">C</span>
      <span class="admin-loader-spinner" aria-hidden="true"></span>
      <span class="admin-loader-text">Préparation de votre espace…</span>
    </div>
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside
        id="admin-sidebar"
        class="fixed inset-y-0 left-0 z-40 w-64 -translate-x-full lg:translate-x-0 transition-transform duration-300 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 flex flex-col"
      >
        <div class="h-16 flex items-center gap-2 px-6 border-b border-gray-200 dark:border-gray-800">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-green-600 text-white font-bold">C</span>
          <span class="font-bold text-lg">CSE <span class="text-green-600">Admin</span></span>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              data-nav
              data-perm={item.perm ?? ''}
              class:list={[
                'flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
                active === item.id
                  ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400'
                  : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800',
              ]}
            >
              <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="px-3 py-4 border-t border-gray-200 dark:border-gray-800">
          <a
            href={withBase('/')}
            class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Voir le site
          </a>
        </div>
      </aside>

      <!-- Overlay mobile -->
      <div id="admin-overlay" class="fixed inset-0 z-30 bg-black/40 hidden lg:hidden"></div>

      <!-- Contenu -->
      <div class="flex-1 lg:ml-64 flex flex-col min-w-0">
        <header class="sticky top-0 z-20 h-16 flex items-center justify-between gap-4 px-4 sm:px-6 bg-white/90 dark:bg-gray-900/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
          <div class="flex items-center gap-3">
            <button id="admin-menu-btn" class="lg:hidden p-2 -ml-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="Menu">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
            <h1 class="text-lg font-semibold">{title}</h1>
          </div>
          <div class="flex items-center gap-3">
            <span
              class:list={[
                'hidden md:inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium',
                isSupabaseEnabled
                  ? 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400'
                  : 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400',
              ]}
              title={isSupabaseEnabled ? 'Connecté à la base de données Supabase' : 'Aucune base de données configurée — données de démonstration locales'}
            >
              <span class:list={['h-1.5 w-1.5 rounded-full', isSupabaseEnabled ? 'bg-green-500' : 'bg-amber-500']}></span>
              {isSupabaseEnabled ? 'Supabase connecté' : 'Mode démo (local)'}
            </span>
            <span class="hidden sm:inline text-sm text-gray-500 dark:text-gray-400">
              Connecté : <span id="admin-username" class="font-medium text-gray-700 dark:text-gray-200">—</span>
            </span>
            <button
              id="admin-logout"
              class="inline-flex items-center gap-2 rounded-lg bg-red-50 px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-100 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              Déconnexion
            </button>
          </div>
        </header>

        <main class="flex-1 p-4 sm:p-6 lg:p-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      import { getSession, restoreSession, logout, can, isSuperAdmin } from '../utils/auth';
      import { rolesRepo, seedRoles } from '../utils/store';
      import { withBase } from '../utils/url';

      const loader = document.getElementById('admin-loader');
      const reveal = () => {
        loader?.classList.add('is-hidden');
        window.setTimeout(() => loader?.remove(), 450);
      };

      // Garde d'accès : redirige vers le login si non authentifié (cache local).
      const session = getSession();
      if (!session) {
        window.location.replace(withBase('/admin/login'));
      } else {
        seedRoles();
        const nameEl = document.getElementById('admin-username');
        if (nameEl) {
          const roleLabel = rolesRepo.get(session.role)?.label ?? session.role;
          nameEl.textContent = `${session.username} (${roleLabel})`;
        }

        // Masque les entrées de navigation non autorisées pour le rôle courant.
        document.querySelectorAll<HTMLElement>('[data-nav]').forEach((el) => {
          const perm = el.dataset.perm;
          if (perm && !can(perm)) el.remove();
        });

        // Masque les actions (boutons, liens) dont le rôle n'a pas la permission.
        document.querySelectorAll<HTMLElement>('[data-requires]').forEach((el) => {
          const perm = el.dataset.requires;
          if (perm && !can(perm)) el.remove();
        });

        // Réservé au super administrateur.
        if (!isSuperAdmin()) {
          document.querySelectorAll<HTMLElement>('[data-superadmin]').forEach((el) => el.remove());
        }

        // En mode Supabase, valide la session réelle (et la rafraîchit) au chargement.
        // Si le rôle a changé côté serveur (ex. promotion superadmin), on recharge
        // pour réafficher les menus avec les bonnes permissions.
        const prevRole = session.role;
        restoreSession().then((s) => {
          if (!s) { window.location.replace(withBase('/admin/login')); return; }
          if (s.role !== prevRole) window.location.reload();
        });

        // Accès validé en local : on révèle la page (l'écran de chargement disparaît).
        reveal();
      }

      // Déconnexion
      document.getElementById('admin-logout')?.addEventListener('click', async () => {
        await logout();
        window.location.replace(withBase('/admin/login'));
      });

      // Sidebar mobile
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('admin-overlay');
      const openBtn = document.getElementById('admin-menu-btn');
      const toggle = (open: boolean) => {
        sidebar?.classList.toggle('-translate-x-full', !open);
        overlay?.classList.toggle('hidden', !open);
      };
      openBtn?.addEventListener('click', () => toggle(true));
      overlay?.addEventListener('click', () => toggle(false));
    </script>
  </body>
</html>

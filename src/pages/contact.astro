---
import Layout from '../layouts/Layout.astro';

const contactInfo = {
  phone: '032 75 170 48 / +261 34 21 807 57',
  email: 'camping.storeevent@gmail.com',
  address: 'Lazaret nord, Antsiranana MADAGASCAR',
  hours: [
    { day: 'Lundi - Vendredi', time: '9h - 18h' },
    { day: 'Samedi', time: '10h - 17h' },
    { day: 'Dimanche', time: 'Fermé' },
  ],
};

const services = ['Réservation', 'Informations', 'Location de matériel', 'Événements', 'Autre demande'];

const inputClass =
  'peer block w-full rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-3 text-gray-900 dark:text-white placeholder-transparent focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition';
const labelClass =
  'absolute left-4 -top-2.5 bg-white dark:bg-gray-800 px-1 text-xs font-medium text-gray-500 dark:text-gray-400 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-400 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-green-600 dark:peer-focus:text-green-400';
---

<Layout title="Contact - Camping Store & Event Madagascar" description="Contactez-nous pour toute question, réservation ou organisation d'événement à Madagascar.">
  <!-- HERO compact -->
  <section class="relative overflow-hidden">
    <img class="absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?q=80&w=1600&auto=format&fit=crop" alt="Nature à Madagascar" />
    <div class="absolute inset-0 bg-gradient-to-br from-gray-950/90 via-gray-900/75 to-green-900/60"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-green-500/20 border border-green-400/30 text-green-300 px-4 py-1.5 text-sm font-semibold backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span> On vous répond sous 24 h
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold text-white">Parlons de votre prochaine aventure</h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-200">Une question, une réservation, un événement à organiser ? Notre équipe est à votre écoute.</p>
    </div>
  </section>

  <!-- CARTE CHEVAUCHANTE : infos + formulaire -->
  <section class="bg-gray-50 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 sm:-mt-20 pb-16 relative z-10">
      <div class="grid lg:grid-cols-5 rounded-3xl overflow-hidden shadow-2xl bg-white dark:bg-gray-800">
        <!-- Panneau infos (vert) -->
        <div class="lg:col-span-2 relative bg-gradient-to-br from-green-600 to-emerald-700 p-8 sm:p-10 text-white overflow-hidden">
          <div class="absolute -top-12 -right-12 h-44 w-44 rounded-full bg-white/10"></div>
          <div class="absolute -bottom-16 -left-10 h-52 w-52 rounded-full bg-white/10"></div>
          <div class="relative">
            <h2 class="text-2xl font-bold">Nos coordonnées</h2>
            <p class="mt-2 text-green-50 text-sm">Passez nous voir, appelez ou écrivez-nous.</p>

            <ul class="mt-8 space-y-6">
              <li class="flex items-start gap-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </span>
                <div>
                  <p class="font-semibold">Adresse</p>
                  <p class="text-green-50 text-sm">{contactInfo.address}</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </span>
                <div>
                  <p class="font-semibold">Téléphone</p>
                  <a href={`tel:${contactInfo.phone.replace(/\s+/g, '').split('/')[0]}`} class="text-green-50 text-sm hover:text-white transition-colors">{contactInfo.phone}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </span>
                <div>
                  <p class="font-semibold">Email</p>
                  <a href={`mailto:${contactInfo.email}`} class="text-green-50 text-sm hover:text-white transition-colors break-all">{contactInfo.email}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </span>
                <div class="w-full">
                  <p class="font-semibold">Horaires</p>
                  <dl class="mt-1 space-y-1">
                    {contactInfo.hours.map((h) => (
                      <div class="flex justify-between gap-4 text-sm text-green-50">
                        <dt>{h.day}</dt>
                        <dd class="font-medium text-white">{h.time}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="lg:col-span-3 p-8 sm:p-10">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Écrivez-nous</h2>
          <p class="mt-1 text-gray-500 dark:text-gray-400 text-sm">Les champs marqués d'un * sont obligatoires.</p>

          <div id="contact-success" class="hidden mt-6 flex items-start gap-3 rounded-xl bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 px-4 py-3 text-green-800 dark:text-green-300">
            <span class="text-lg">✅</span>
            <span>Merci ! Votre message a bien été envoyé, nous vous répondrons rapidement.</span>
          </div>

          <form id="contact-form" class="mt-6 space-y-6">
            <div class="grid sm:grid-cols-2 gap-6">
              <div class="relative">
                <input id="name" type="text" placeholder="Nom" class={inputClass} />
                <label for="name" class={labelClass}>Nom *</label>
              </div>
              <div class="relative">
                <input id="email" type="email" placeholder="Email" class={inputClass} />
                <label for="email" class={labelClass}>Email *</label>
              </div>
            </div>
            <div class="grid sm:grid-cols-2 gap-6">
              <div class="relative">
                <input id="phone" type="tel" placeholder="Téléphone" class={inputClass} />
                <label for="phone" class={labelClass}>Téléphone</label>
              </div>
              <div class="relative">
                <select id="service" class="block w-full rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition">
                  {services.map((s) => <option value={s}>{s}</option>)}
                </select>
                <label for="service" class="absolute left-4 -top-2.5 bg-white dark:bg-gray-800 px-1 text-xs font-medium text-gray-500 dark:text-gray-400">Sujet</label>
              </div>
            </div>
            <div class="relative">
              <textarea id="message" rows="6" placeholder="Message" class={inputClass}></textarea>
              <label for="message" class={labelClass}>Votre message *</label>
            </div>
            <button type="submit" class="group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 px-8 py-3.5 text-base font-bold text-white transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
              Envoyer le message
              <svg class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </button>
          </form>
        </div>
      </div>

      <!-- Bandeaux atouts -->
      <div class="grid sm:grid-cols-3 gap-4 mt-8">
        {[
          { icon: '⚡', title: 'Réponse rapide', text: 'Sous 24 h ouvrées' },
          { icon: '🅿️', title: 'Parking gratuit', text: 'Sur place pour nos clients' },
          { icon: '🤝', title: 'Conseils experts', text: 'Une équipe passionnée' },
        ].map((b) => (
          <div class="flex items-center gap-3 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 p-4">
            <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-green-100 dark:bg-green-900/40 text-2xl">{b.icon}</span>
            <div>
              <p class="font-semibold text-gray-900 dark:text-white">{b.title}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">{b.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CARTE -->
  <section class="bg-gray-50 dark:bg-gray-900 pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl overflow-hidden shadow-lg border border-gray-100 dark:border-gray-800">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7921.81916399046!2d49.2915!3d-12.2792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTLCsDE2JzQ1LjEiUyA0OcKwMTcnMDEuMSJF!5e0!3m2!1sfr!2smg!4v1629999999999!5m2!1sfr!2smg"
          width="100%" height="360" style="border:0;" allowfullscreen="" loading="lazy"
          class="w-full" title="Carte — Antsiranana, Madagascar"></iframe>
      </div>
    </div>
  </section>

  <script>
    import { messagesData } from '../utils/db';

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('contact-success');
    const value = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null)?.value.trim() ?? '';

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = value('name');
      const email = value('email');
      const message = value('message');
      if (!name || !email || !message) {
        alert('Merci de renseigner au moins votre nom, votre email et votre message.');
        return;
      }
      await messagesData.create({
        name,
        email,
        phone: value('phone') || undefined,
        service: value('service') || 'Autre demande',
        message,
        status: 'new',
        date: new Date().toISOString(),
      });
      form.reset();
      success?.classList.remove('hidden');
      success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  </script>
</Layout>

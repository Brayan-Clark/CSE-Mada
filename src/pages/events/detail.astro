---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../utils/url';
---

<Layout title="Événement" description="Détail de l'événement">
  <article class="min-h-screen bg-white dark:bg-gray-900 pb-20">
    <!-- Hero -->
    <div id="ev-hero" class="relative h-[45vh] min-h-[360px] w-full overflow-hidden bg-gradient-to-br from-green-700 to-emerald-800">
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900/85 via-gray-900/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        <span id="ev-activity" class="hidden inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-600 text-white mb-4 shadow-lg"></span>
        <h1 id="ev-title" class="text-3xl md:text-5xl font-bold text-white leading-tight"></h1>
        <div class="mt-3 flex flex-wrap gap-5 text-gray-200">
          <span id="ev-date" class="inline-flex items-center gap-2 capitalize"></span>
          <span id="ev-location" class="hidden items-center gap-2"></span>
        </div>
      </div>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 md:p-10 border border-gray-100 dark:border-gray-700">
        <p id="ev-description" class="hidden text-xl text-gray-600 dark:text-gray-300 font-medium mb-6"></p>
        <div id="ev-content" class="prose prose-lg dark:prose-invert max-w-none"></div>
        <div id="ev-actions" class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-700">
          <a href={withBase('/contact')} class="inline-flex items-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 transition-colors">Je participe / Demander des infos</a>
        </div>
      </div>

      <!-- Introuvable -->
      <div id="ev-missing" class="hidden text-center py-16">
        <p class="text-4xl mb-3">🔍</p>
        <p class="text-gray-500 dark:text-gray-400">Cet événement est introuvable.</p>
        <a href={withBase('/events')} class="mt-4 inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">← Retour aux événements</a>
      </div>

      <div class="mt-8">
        <a href={withBase('/events')} class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-green-700 dark:hover:text-green-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          Retour à l'agenda
        </a>
      </div>
    </div>
  </article>

  <script>
    import { eventsData } from '../../utils/db';
    import { withBase } from '../../utils/url';
    import { marked } from 'marked';

    const $ = (id: string) => document.getElementById(id)!;
    const id = new URLSearchParams(window.location.search).get('id');

    function showMissing() {
      $('ev-hero').classList.add('hidden');
      $('ev-description').classList.add('hidden');
      $('ev-content').classList.add('hidden');
      $('ev-actions').classList.add('hidden');
      $('ev-missing').classList.remove('hidden');
    }

    const ev = id ? await eventsData.get(id) : undefined;
    if (!ev) {
      showMissing();
    } else {
      document.title = `${ev.title} | Camping Store & Event`;
      if (ev.image) {
        const img = document.createElement('img');
        img.src = withBase(ev.image);
        img.alt = ev.title;
        img.className = 'absolute inset-0 w-full h-full object-cover';
        $('ev-hero').prepend(img);
      }
      $('ev-title').textContent = ev.title;

      const d = new Date(ev.date);
      const fdate = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }).format(d);
      $('ev-date').innerHTML = `<svg class="h-5 w-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg><span>${fdate}</span>`;

      if (ev.location) {
        const loc = $('ev-location');
        loc.classList.remove('hidden'); loc.classList.add('flex');
        loc.innerHTML = `<svg class="h-5 w-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg><span>${ev.location}</span>`;
      }
      if (ev.activity) {
        const a = $('ev-activity');
        a.classList.remove('hidden');
        a.textContent = ev.activity;
      }
      if (ev.description) {
        $('ev-description').classList.remove('hidden');
        $('ev-description').textContent = ev.description;
      }
      if (ev.content && ev.content.trim()) {
        $('ev-content').innerHTML = await marked.parse(ev.content);
      } else {
        $('ev-content').innerHTML = '<p class="text-gray-500 dark:text-gray-400">Plus d\'informations bientôt. Contactez-nous pour en savoir plus.</p>';
      }
    }
  </script>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../utils/url';
---

<Layout title="Événement" description="Détail de l'événement">
  <article class="min-h-screen bg-white dark:bg-gray-900 pb-20">
    <div id="ev-root"></div>

    <!-- Introuvable -->
    <div id="ev-missing" class="hidden max-w-3xl mx-auto px-4 text-center py-24">
      <p class="text-4xl mb-3">🔍</p>
      <p class="text-gray-500 dark:text-gray-400">Cet événement est introuvable.</p>
      <a href={withBase('/events')} class="mt-4 inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">← Retour aux événements</a>
    </div>
  </article>

  <script>
    import { eventsData } from '../../utils/db';
    import { withBase } from '../../utils/url';
    import { marked } from 'marked';

    const id = new URLSearchParams(window.location.search).get('id');
    const root = document.getElementById('ev-root')!;
    const escape = (s: string) =>
      String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const ev = id ? await eventsData.get(id) : undefined;
    if (!ev) {
      document.getElementById('ev-missing')!.classList.remove('hidden');
    } else {
      document.title = `${ev.title} | Camping Store & Event`;
      const d = new Date(ev.date);
      const fdate = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }).format(d);
      const isPast = d.getTime() < Date.now();
      const hasContent = !!(ev.content && ev.content.trim());
      const img = ev.image ? withBase(ev.image) : '';

      // Corps : si contenu détaillé → on l'affiche ; sinon l'image en grand (flyer).
      let mainInner: string;
      if (hasContent) {
        mainInner = `<div class="prose prose-lg dark:prose-invert max-w-none">${await marked.parse(ev.content!)}</div>`;
      } else if (img) {
        mainInner = `<div class="w-full rounded-xl overflow-hidden shadow-lg"><img src="${escape(img)}" alt="${escape(ev.title)}" class="w-full h-auto" /></div>`;
      } else {
        mainInner = '<p class="text-gray-500 dark:text-gray-400">Plus d\'informations bientôt. Contactez-nous pour en savoir plus.</p>';
      }

      const heroBg = img
        ? `<div class="absolute inset-0"><img src="${escape(img)}" alt="${escape(ev.title)}" class="w-full h-full object-cover" /><div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent"></div></div>`
        : '<div class="absolute inset-0 bg-gradient-to-br from-green-700 to-emerald-800"></div>';

      const activityBadge = ev.activity
        ? `<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-600 text-white mb-4 shadow-lg">${escape(ev.activity)}</span>`
        : '';

      const locationLine = ev.location
        ? `<div class="flex items-center"><svg class="h-6 w-6 mr-2 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>${escape(ev.location)}</div>`
        : '';

      // Boutons de la barre latérale.
      // Le bouton galerie est TOUJOURS affiché : « Voir la galerie » si des
      // photos existent, sinon « Galerie à venir » (la page galerie indiquera
      // qu'elle arrive bientôt).
      const galleryHref = withBase(`/events/gallery?id=${encodeURIComponent(ev.id)}`);
      const galleryBtn = ev.galleryFolder
        ? `<a href="${galleryHref}" class="block w-full text-center bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-4 rounded-xl transition-colors shadow-md hover:shadow-lg">Voir la galerie photo</a>`
        : `<a href="${galleryHref}" class="block w-full text-center bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 font-semibold py-3 px-4 rounded-xl transition-colors">Galerie à venir</a>`;
      const participateBtn = !isPast
        ? `<a href="${withBase('/reservation')}" class="block w-full text-center mt-3 border border-green-600 text-green-700 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30 font-semibold py-3 px-4 rounded-xl transition-colors">Je participe / Réserver</a>`
        : '';
      const sidebarActions = `<div class="mt-8">${galleryBtn}${participateBtn}</div>`;

      const sidebarRows = [
        `<div><span class="block text-sm text-gray-500 dark:text-gray-400">Date</span><span class="block font-medium text-gray-900 dark:text-white capitalize">${fdate}</span></div>`,
        ev.location ? `<div><span class="block text-sm text-gray-500 dark:text-gray-400">Lieu</span><span class="block font-medium text-gray-900 dark:text-white">${escape(ev.location)}</span></div>` : '',
        ev.activity ? `<div><span class="block text-sm text-gray-500 dark:text-gray-400">Type d'activité</span><span class="block font-medium text-gray-900 dark:text-white">${escape(ev.activity)}</span></div>` : '',
      ].join('');

      root.innerHTML = `
        <div class="relative h-[50vh] min-h-[360px] w-full overflow-hidden">
          ${heroBg}
          <div class="absolute bottom-0 left-0 right-0 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
            <div class="max-w-3xl">
              ${activityBadge}
              <h1 class="text-3xl md:text-5xl font-bold text-white mb-3 leading-tight">${escape(ev.title)}</h1>
              <div class="flex flex-wrap gap-6 text-gray-200 text-lg">
                <div class="flex items-center"><svg class="h-6 w-6 mr-2 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg><span class="capitalize">${fdate}</span></div>
                ${locationLine}
              </div>
            </div>
          </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1 min-w-0">
              <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 md:p-10 border border-gray-100 dark:border-gray-700">
                ${mainInner}
              </div>
              <a href="${withBase('/events')}" class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-green-700 dark:hover:text-green-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                Retour à l'agenda
              </a>
            </div>
            <div class="lg:w-80 flex-shrink-0">
              <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-gray-100 dark:border-gray-700 lg:sticky lg:top-24">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-b border-gray-200 dark:border-gray-700 pb-2">Détails pratiques</h3>
                <div class="space-y-4">${sidebarRows}</div>
                ${sidebarActions}
              </div>
            </div>
          </div>
        </div>`;
    }
  </script>
</Layout>

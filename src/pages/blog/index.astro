---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../utils/url';

// Articles triés par date (plus récent d'abord)
const allPosts = (
  await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allPosts[0];

// Tags uniques pour les filtres
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d));
const readTime = (post: (typeof allPosts)[number]) =>
  Math.max(1, Math.round((post.body?.split(/\s+/).length ?? 200) / 200));
---

<Layout
  title="Blog - Camping Store & Event Madagascar"
  description="Découvrez nos articles sur le camping, la randonnée et les aventures en pleine nature à Madagascar."
>
  <section class="bg-white dark:bg-gray-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- En-tête -->
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-1.5 text-green-700 dark:text-green-400 text-sm font-semibold uppercase tracking-wide">
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span> Le carnet d'aventures
        </span>
        <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white">Notre Blog</h1>
        <p class="mt-2 text-gray-500 dark:text-gray-400">Conseils, récits d'aventure et actualités sur le camping et la randonnée à Madagascar.</p>
      </div>

      {allPosts.length === 0 && (
        <div class="mt-12 text-center py-20 rounded-2xl border border-dashed border-gray-200 dark:border-gray-800">
          <p class="text-4xl mb-3">📝</p>
          <p class="text-gray-500 dark:text-gray-400 text-lg">Aucun article pour le moment. Revenez bientôt !</p>
        </div>
      )}

      <!-- Article à la une -->
      {featured && (
        <a
          href={withBase(`/blog/${featured.slug}`)}
          class="group grid lg:grid-cols-2 gap-6 lg:gap-10 mt-10 mb-14 items-center"
        >
          <div class="relative rounded-3xl overflow-hidden aspect-[16/10] bg-gray-100 dark:bg-gray-800">
            {featured.data.image ? (
              <img src={withBase(featured.data.image)} alt={featured.data.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-green-500 to-emerald-700"></div>
            )}
            <span class="absolute top-4 left-4 inline-flex rounded-full bg-green-600 text-white px-3 py-1 text-xs font-semibold">À la une</span>
          </div>
          <div>
            {featured.data.tags?.[0] && (
              <span class="text-sm font-semibold uppercase tracking-wide text-green-700 dark:text-green-400">{featured.data.tags[0]}</span>
            )}
            <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white group-hover:text-green-700 dark:group-hover:text-green-400 transition-colors">{featured.data.title}</h2>
            <p class="mt-3 text-gray-600 dark:text-gray-300 line-clamp-3">{featured.data.description}</p>
            <div class="mt-5 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 font-bold">{featured.data.author.charAt(0)}</span>
              <div class="text-sm">
                <p class="font-medium text-gray-900 dark:text-white">{featured.data.author}</p>
                <p class="text-gray-500 dark:text-gray-400">{fmtDate(featured.data.pubDate)} · {readTime(featured)} min de lecture</p>
              </div>
            </div>
          </div>
        </a>
      )}

      {allPosts.length > 0 && (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Tous les articles</h2>
            <!-- Filtres par tag -->
            {tags.length > 0 && (
              <div id="tag-filters" class="flex flex-wrap gap-2">
                <button data-tag="all" class="tag-btn rounded-full px-3 py-1.5 text-sm font-medium bg-green-600 text-white">Tous</button>
                {tags.map((tag) => (
                  <button data-tag={tag.toLowerCase()} class="tag-btn rounded-full px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700">{tag}</button>
                ))}
              </div>
            )}
          </div>

          <div id="posts-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {allPosts.map((post) => (
              <article
                class="post-card group flex flex-col rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 overflow-hidden hover:border-green-300 dark:hover:border-green-700 hover:shadow-md transition-all"
                data-tags={(post.data.tags ?? []).map((t) => t.toLowerCase()).join(',')}
              >
                <a href={withBase(`/blog/${post.slug}`)} class="block aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
                  {post.data.image ? (
                    <img src={withBase(post.data.image)} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-green-500 to-emerald-600"></div>
                  )}
                </a>
                <div class="p-5 flex flex-col flex-1">
                  <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
                    <time datetime={new Date(post.data.pubDate).toISOString()}>{fmtDate(post.data.pubDate)}</time>
                    <span>·</span>
                    <span>{readTime(post)} min</span>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white">
                    <a href={withBase(`/blog/${post.slug}`)} class="hover:text-green-700 dark:hover:text-green-400 transition-colors">{post.data.title}</a>
                  </h3>
                  <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 line-clamp-2 flex-1">{post.data.description}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 rounded-full">{tag}</span>
                      ))}
                    </div>
                  )}
                  <div class="mt-4 pt-3 border-t border-gray-100 dark:border-gray-800 flex items-center justify-between">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Par {post.data.author}</span>
                    <span class="inline-flex items-center gap-1 text-sm font-medium text-green-700 dark:text-green-400 group-hover:gap-2 transition-all">
                      Lire
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </div>
                </div>
              </article>
            ))}
          </div>
          <p id="no-results" class="hidden text-center text-gray-500 dark:text-gray-400 py-12">Aucun article pour ce thème.</p>
        </div>
      )}

      <!-- Newsletter -->
      <div class="mt-16 rounded-2xl bg-gradient-to-r from-green-600 to-emerald-700 p-8 sm:p-10 text-center">
        <h2 class="text-2xl font-bold text-white">Restez informés</h2>
        <p class="mt-2 text-green-50 max-w-xl mx-auto">Recevez nos derniers articles et offres spéciales directement dans votre boîte mail.</p>
        <form id="newsletter-form" class="mt-6 sm:flex max-w-md mx-auto gap-3">
          <label for="email" class="sr-only">Adresse email</label>
          <input id="email" type="email" required placeholder="Votre adresse email" class="block w-full px-5 py-3 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-white" />
          <button type="submit" class="mt-3 sm:mt-0 w-full sm:w-auto px-6 py-3 rounded-lg bg-white text-green-700 font-semibold hover:bg-green-50 transition-colors whitespace-nowrap">S'inscrire</button>
        </form>
        <p class="mt-3 text-sm text-green-100">Nous respectons votre vie privée. Désinscription à tout moment.</p>
      </div>
    </div>
  </section>

  <script>
    // Filtrage par tag (côté client)
    const filters = document.getElementById('tag-filters');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card'));
    const noResults = document.getElementById('no-results');

    filters?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-tag]');
      if (!btn) return;
      const tag = btn.dataset.tag!;
      document.querySelectorAll<HTMLButtonElement>('.tag-btn').forEach((b) => {
        const on = b === btn;
        b.classList.toggle('bg-green-600', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('bg-gray-100', !on);
        b.classList.toggle('dark:bg-gray-800', !on);
        b.classList.toggle('text-gray-700', !on);
        b.classList.toggle('dark:text-gray-300', !on);
      });
      let visible = 0;
      cards.forEach((card) => {
        const tagList = (card.dataset.tags ?? '').split(',');
        const show = tag === 'all' || tagList.includes(tag);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      noResults?.classList.toggle('hidden', visible > 0);
    });

    // Newsletter (démo)
    document.getElementById('newsletter-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('email') as HTMLInputElement;
      if (input.value.trim()) {
        alert('Merci pour votre inscription à notre newsletter !');
        input.value = '';
      }
    });
  </script>
</Layout>

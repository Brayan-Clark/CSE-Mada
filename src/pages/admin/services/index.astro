---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ViewToggle from '../../../components/admin/ViewToggle.astro';

const inputClass =
  'w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent';
---

<AdminLayout title="Services" active="services">
  <div class="flex items-center justify-between gap-4 mb-6">
    <p class="text-sm text-gray-500 dark:text-gray-400"><span id="service-count">0</span> service(s)</p>
    <div class="flex items-center gap-3">
      <ViewToggle />
      <button id="add-service" data-requires="services.manage" class="inline-flex items-center gap-2 rounded-lg bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 text-sm font-medium transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
        Nouveau service
      </button>
    </div>
  </div>

  <div id="services-grid"></div>
  <p id="empty-state" class="hidden px-4 py-10 text-center text-gray-400">Aucun service pour le moment.</p>

  <!-- Modale -->
  <div id="service-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-6 shadow-xl max-h-[90vh] overflow-y-auto">
      <h3 id="modal-title" class="text-lg font-bold mb-5">Nouveau service</h3>
      <form id="service-form" class="space-y-4">
        <input type="hidden" id="service-id" />
        <div class="grid gap-4 sm:grid-cols-[5rem_1fr]">
          <div>
            <label for="icon" class="block text-sm font-medium mb-1.5">Icône</label>
            <input id="icon" type="text" maxlength="2" placeholder="⛺" class={`${inputClass} text-center text-xl`} />
          </div>
          <div>
            <label for="title" class="block text-sm font-medium mb-1.5">Titre *</label>
            <input id="title" type="text" required class={inputClass} />
          </div>
        </div>
        <div>
          <label for="description" class="block text-sm font-medium mb-1.5">Description</label>
          <textarea id="description" rows="3" class={inputClass}></textarea>
        </div>
        <div>
          <label for="features" class="block text-sm font-medium mb-1.5">Points forts <span class="font-normal text-gray-400">(un par ligne)</span></label>
          <textarea id="features" rows="4" placeholder="Matériel de qualité&#10;Conseils d'experts" class={inputClass}></textarea>
        </div>
        <div>
          <label for="image" class="block text-sm font-medium mb-1.5">Image (URL)</label>
          <input id="image" type="text" placeholder="https://…" class={inputClass} />
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium px-5 py-2.5 text-sm transition-colors">Enregistrer</button>
          <button type="button" id="modal-cancel" class="rounded-lg border border-gray-200 dark:border-gray-700 px-5 py-2.5 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Annuler</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { DEFAULT_SERVICES } from '../../../utils/store';
    import type { Service } from '../../../utils/store';
    import { servicesData } from '../../../utils/db';
    import { can } from '../../../utils/auth';
    import { getViewMode, setViewMode } from '../../../utils/view-pref';

    servicesData.seedIfEmpty(DEFAULT_SERVICES);

    const canManage = can('services.manage');
    let viewMode = getViewMode('services');
    const grid = document.getElementById('services-grid')!;
    const empty = document.getElementById('empty-state')!;
    const count = document.getElementById('service-count')!;
    const modal = document.getElementById('service-modal')!;
    const form = document.getElementById('service-form') as HTMLFormElement;
    const title = document.getElementById('modal-title')!;
    const f = (id: string) => document.getElementById(id) as HTMLInputElement;

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function actionBtns(s: { id: string; title: string }) {
      return canManage
        ? `<button data-edit="${escape(s.id)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30">Éditer</button>
           <button data-delete="${escape(s.id)}" data-name="${escape(s.title)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30">Supprimer</button>`
        : '';
    }

    async function render() {
      const services = await servicesData.list();
      count.textContent = String(services.length);
      empty.classList.toggle('hidden', services.length > 0);

      grid.className = viewMode === 'grid' ? 'grid gap-4 sm:grid-cols-2 lg:grid-cols-3' : 'space-y-2';

      grid.innerHTML = services
        .map((s) => {
          if (viewMode === 'list') {
            return `
              <article class="flex items-center gap-4 rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-3">
                <div class="text-2xl shrink-0">${escape(s.icon || '•')}</div>
                <div class="min-w-0 flex-1">
                  <p class="font-semibold truncate">${escape(s.title)}</p>
                  <p class="text-xs text-gray-400 truncate">${escape(s.description)}</p>
                </div>
                <div class="flex gap-1 shrink-0">${actionBtns(s)}</div>
              </article>`;
          }
          const feats = s.features
            .map((feat) => `<li class="flex items-start gap-1.5"><span class="text-green-600 mt-0.5">✓</span><span>${escape(feat)}</span></li>`)
            .join('');
          const actions = canManage
            ? `<div class="flex gap-2 border-t border-gray-100 dark:border-gray-800 pt-3 mt-3">${actionBtns(s)}</div>`
            : '';
          return `
            <article class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-5 flex flex-col">
              <div class="text-3xl">${escape(s.icon || '•')}</div>
              <h3 class="font-semibold mt-2">${escape(s.title)}</h3>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">${escape(s.description)}</p>
              <ul class="mt-3 space-y-1 text-sm text-gray-600 dark:text-gray-300 flex-1">${feats}</ul>
              ${actions}
            </article>`;
        })
        .join('');
    }

    function syncToggle() {
      document.querySelectorAll<HTMLButtonElement>('[data-view-btn]').forEach((b) => {
        const on = b.dataset.viewBtn === viewMode;
        b.classList.toggle('bg-green-600', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('text-gray-500', !on);
        b.classList.toggle('dark:text-gray-400', !on);
      });
    }
    document.querySelectorAll<HTMLButtonElement>('[data-view-btn]').forEach((b) => {
      b.addEventListener('click', () => {
        viewMode = b.dataset.viewBtn as 'grid' | 'list';
        setViewMode('services', viewMode);
        syncToggle();
        render();
      });
    });
    syncToggle();

    function openModal(service?: Service) {
      title.textContent = service ? 'Modifier le service' : 'Nouveau service';
      f('service-id').value = service?.id ?? '';
      f('icon').value = service?.icon ?? '';
      f('title').value = service?.title ?? '';
      (document.getElementById('description') as HTMLTextAreaElement).value = service?.description ?? '';
      (document.getElementById('features') as HTMLTextAreaElement).value = service?.features.join('\n') ?? '';
      f('image').value = service?.image ?? '';
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.getElementById('add-service')?.addEventListener('click', () => openModal());
    document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    grid.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const edit = target.closest<HTMLButtonElement>('[data-edit]');
      if (edit) {
        const s = await servicesData.get(edit.dataset.edit!);
        if (s) openModal(s);
        return;
      }
      const del = target.closest<HTMLButtonElement>('[data-delete]');
      if (del && confirm(`Supprimer le service « ${del.dataset.name} » ?`)) {
        await servicesData.remove(del.dataset.delete!);
        await render();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = {
        icon: f('icon').value.trim() || '•',
        title: f('title').value.trim(),
        description: (document.getElementById('description') as HTMLTextAreaElement).value.trim(),
        features: (document.getElementById('features') as HTMLTextAreaElement).value
          .split('\n').map((l) => l.trim()).filter(Boolean),
        image: f('image').value.trim() || undefined,
      };
      const id = f('service-id').value;
      if (id) await servicesData.update(id, data);
      else await servicesData.create(data);
      closeModal();
      await render();
    });

    render();
  </script>
</AdminLayout>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Commandes" active="orders">
  <!-- Statistiques rapides -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-6">
    <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Total commandes</p>
      <p id="kpi-total" class="mt-1 text-2xl font-bold">0</p>
    </div>
    <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Nouvelles</p>
      <p id="kpi-new" class="mt-1 text-2xl font-bold text-amber-600 dark:text-amber-400">0</p>
    </div>
    <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Livrées</p>
      <p id="kpi-delivered" class="mt-1 text-2xl font-bold text-green-600 dark:text-green-400">0</p>
    </div>
    <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Chiffre d'affaires</p>
      <p id="kpi-revenue" class="mt-1 text-2xl font-bold">0 Ar</p>
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
    <p class="text-sm text-gray-500 dark:text-gray-400"><span id="order-count">0</span> commande(s)</p>
    <div class="flex gap-2 overflow-x-auto" id="status-filters">
      <button data-filter="all" class="filter-btn whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium bg-green-600 text-white">Toutes</button>
      <button data-filter="new" class="filter-btn whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Nouvelles</button>
      <button data-filter="confirmed" class="filter-btn whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Confirmées</button>
      <button data-filter="delivered" class="filter-btn whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Livrées</button>
      <button data-filter="cancelled" class="filter-btn whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Annulées</button>
    </div>
  </div>

  <div id="orders-list" class="space-y-3"></div>
  <p id="empty-state" class="hidden px-4 py-10 text-center text-gray-400">Aucune commande pour le moment.</p>

  <!-- Modale détail -->
  <div id="order-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div id="order-backdrop" class="absolute inset-0 bg-black/50"></div>
    <div class="relative w-full max-w-lg rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-6 shadow-xl max-h-[90vh] overflow-y-auto">
      <button id="order-close" class="absolute top-4 right-4 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="Fermer">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <h3 id="om-ref" class="text-lg font-bold"></h3>
      <p id="om-date" class="text-sm text-gray-400 mt-0.5"></p>

      <div class="mt-4 rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-sm space-y-1">
        <p><span class="text-gray-500 dark:text-gray-400">Client :</span> <span id="om-name" class="font-medium"></span></p>
        <p><span class="text-gray-500 dark:text-gray-400">Email :</span> <a id="om-email" class="text-green-700 dark:text-green-400 hover:underline" href="#"></a></p>
        <p id="om-phone-row"><span class="text-gray-500 dark:text-gray-400">Téléphone :</span> <span id="om-phone"></span></p>
      </div>

      <div id="om-note-row" class="mt-3 text-sm">
        <p class="text-gray-500 dark:text-gray-400 mb-1">Note du client :</p>
        <p id="om-note" class="rounded-lg bg-amber-50 dark:bg-amber-900/20 p-3 text-gray-700 dark:text-gray-200"></p>
      </div>

      <h4 class="mt-4 mb-2 text-sm font-semibold">Articles</h4>
      <div id="om-items" class="divide-y divide-gray-100 dark:divide-gray-800 text-sm"></div>
      <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-200 dark:border-gray-700 font-bold">
        <span>Total</span>
        <span id="om-total" class="text-green-700 dark:text-green-400"></span>
      </div>

      <div class="mt-5" data-requires="orders.manage">
        <label for="om-status" class="block text-sm font-medium mb-1.5">Statut de la commande</label>
        <select id="om-status" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          <option value="new">Nouvelle</option>
          <option value="confirmed">Confirmée</option>
          <option value="delivered">Livrée</option>
          <option value="cancelled">Annulée</option>
        </select>
        <div class="flex gap-3 mt-4">
          <button id="om-save" class="rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium px-5 py-2.5 text-sm transition-colors">Enregistrer</button>
          <button id="om-delete" class="rounded-lg border border-red-200 dark:border-red-900 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 px-5 py-2.5 text-sm font-medium transition-colors">Supprimer</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import type { Order, OrderStatus } from '../../../utils/store';
    import { ordersData } from '../../../utils/db';
    import { can } from '../../../utils/auth';
    import { formatMGA } from '../../../utils/format';

    const canManage = can('orders.manage');
    const $ = (id: string) => document.getElementById(id)!;
    const list = $('orders-list');
    const empty = $('empty-state');
    const modal = $('order-modal');
    let filter: 'all' | OrderStatus = 'all';
    let currentId: string | null = null;

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const STATUS: Record<OrderStatus, { label: string; cls: string }> = {
      new: { label: 'Nouvelle', cls: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400' },
      confirmed: { label: 'Confirmée', cls: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400' },
      delivered: { label: 'Livrée', cls: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400' },
      cancelled: { label: 'Annulée', cls: 'bg-gray-200 text-gray-600 dark:bg-gray-700 dark:text-gray-300' },
    };

    const fmtDate = (iso: string) =>
      new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });

    function renderKpis(orders: Order[]) {
      $('kpi-total').textContent = String(orders.length);
      $('kpi-new').textContent = String(orders.filter((o) => o.status === 'new').length);
      $('kpi-delivered').textContent = String(orders.filter((o) => o.status === 'delivered').length);
      const rev = orders.filter((o) => o.status !== 'cancelled').reduce((s, o) => s + (o.total || 0), 0);
      $('kpi-revenue').textContent = formatMGA(rev);
    }

    async function render() {
      const all = (await ordersData.list()).sort((a, b) => b.date.localeCompare(a.date));
      renderKpis(all);
      const orders = filter === 'all' ? all : all.filter((o) => o.status === filter);
      $('order-count').textContent = String(orders.length);
      empty.classList.toggle('hidden', orders.length > 0);
      list.innerHTML = orders.map((o) => {
        const s = STATUS[o.status];
        const count = o.items.reduce((n, i) => n + i.quantity, 0);
        return `
          <button data-open="${escape(o.id)}" class="w-full text-left rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4 hover:border-green-300 dark:hover:border-green-700 transition-colors">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div class="flex items-center gap-3">
                <span class="font-bold">${escape(o.reference)}</span>
                <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium ${s.cls}">${s.label}</span>
              </div>
              <span class="font-bold text-green-700 dark:text-green-400">${formatMGA(o.total)}</span>
            </div>
            <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 dark:text-gray-400">
              <span>${escape(o.customer.name)}</span>
              <span>·</span>
              <span>${count} article${count > 1 ? 's' : ''}</span>
              <span>·</span>
              <span>${fmtDate(o.date)}</span>
            </div>
          </button>`;
      }).join('');
    }

    async function openOrder(id: string) {
      const o = await ordersData.get(id);
      if (!o) return;
      currentId = id;
      $('om-ref').textContent = o.reference;
      $('om-date').textContent = fmtDate(o.date);
      $('om-name').textContent = o.customer.name;
      const emailEl = $('om-email') as HTMLAnchorElement;
      emailEl.textContent = o.customer.email;
      emailEl.href = `mailto:${o.customer.email}`;
      $('om-phone-row').classList.toggle('hidden', !o.customer.phone);
      $('om-phone').textContent = o.customer.phone ?? '';
      $('om-note-row').classList.toggle('hidden', !o.note);
      $('om-note').textContent = o.note ?? '';
      $('om-items').innerHTML = o.items.map((i) => `
        <div class="flex items-center justify-between py-2">
          <span>${escape(i.name)} <span class="text-gray-400">× ${i.quantity}</span></span>
          <span class="font-medium">${formatMGA(i.price * i.quantity)}</span>
        </div>`).join('');
      $('om-total').textContent = formatMGA(o.total);
      ($('om-status') as HTMLSelectElement).value = o.status;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeOrder() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      currentId = null;
    }

    list.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-open]');
      if (btn) openOrder(btn.dataset.open!);
    });

    $('status-filters').addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
      if (!btn) return;
      filter = btn.dataset.filter as typeof filter;
      document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
        const on = b.dataset.filter === filter;
        b.classList.toggle('bg-green-600', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('bg-gray-100', !on);
        b.classList.toggle('dark:bg-gray-800', !on);
        b.classList.toggle('text-gray-700', !on);
        b.classList.toggle('dark:text-gray-300', !on);
      });
      render();
    });

    $('order-close').addEventListener('click', closeOrder);
    $('order-backdrop').addEventListener('click', closeOrder);

    if (canManage) {
      $('om-save').addEventListener('click', async () => {
        if (!currentId) return;
        await ordersData.update(currentId, { status: ($('om-status') as HTMLSelectElement).value as OrderStatus });
        closeOrder();
        await render();
      });
      $('om-delete').addEventListener('click', async () => {
        if (!currentId) return;
        if (confirm('Supprimer définitivement cette commande ?')) {
          await ordersData.remove(currentId);
          closeOrder();
          await render();
        }
      });
    }

    render();
  </script>
</AdminLayout>

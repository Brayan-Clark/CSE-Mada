---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getEventSeed } from '../../../utils/content';

const eventSeed = await getEventSeed();
const inputClass =
  'w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent';
---

<AdminLayout title="Événements" active="events">
  <script type="application/json" id="event-seed" set:html={JSON.stringify(eventSeed)} />

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
    <p class="text-sm text-gray-500 dark:text-gray-400"><span id="event-count">0</span> événement(s)</p>
    <div class="flex items-center gap-3">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" /></svg>
        <input id="event-search" type="search" placeholder="Rechercher…" class="w-full sm:w-52 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 pl-9 pr-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
      </div>
      <select id="event-filter" class="rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
        <option value="all">Tous</option>
        <option value="upcoming">À venir</option>
        <option value="past">Passés</option>
        <option value="published">Publiés</option>
        <option value="draft">Brouillons</option>
      </select>
      <button id="add-event" data-requires="events.manage" class="inline-flex items-center gap-2 rounded-lg bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
        Nouvel événement
      </button>
    </div>
  </div>

  <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800/50 text-left text-gray-500 dark:text-gray-400">
          <tr>
            <th class="px-4 py-3 font-medium">Titre</th>
            <th class="px-4 py-3 font-medium">Date</th>
            <th class="px-4 py-3 font-medium">Lieu</th>
            <th class="px-4 py-3 font-medium">Statut</th>
            <th class="px-4 py-3 font-medium text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="events-body" class="divide-y divide-gray-100 dark:divide-gray-800"></tbody>
      </table>
    </div>
    <p id="empty-state" class="hidden px-4 py-10 text-center text-gray-400">Aucun événement.</p>
  </div>

  <!-- Modale -->
  <div id="event-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-6 shadow-xl max-h-[90vh] overflow-y-auto">
      <h3 id="modal-title" class="text-lg font-bold mb-5">Nouvel événement</h3>
      <form id="event-form" class="space-y-4">
        <input type="hidden" id="event-id" />
        <div>
          <label for="title" class="block text-sm font-medium mb-1.5">Titre *</label>
          <input id="title" type="text" required class={inputClass} />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="date" class="block text-sm font-medium mb-1.5">Date</label>
            <input id="date" type="date" class={inputClass} />
          </div>
          <div>
            <label for="location" class="block text-sm font-medium mb-1.5">Lieu</label>
            <input id="location" type="text" class={inputClass} />
          </div>
        </div>
        <div>
          <label for="activity" class="block text-sm font-medium mb-1.5">Activité</label>
          <input id="activity" type="text" placeholder="Randonnée, Camping…" class={inputClass} />
        </div>
        <div>
          <label for="description" class="block text-sm font-medium mb-1.5">Description <span class="font-normal text-gray-400">(résumé court affiché dans les listes)</span></label>
          <textarea id="description" rows="2" class={inputClass}></textarea>
        </div>
        <div>
          <label for="content" class="block text-sm font-medium mb-1.5">Contenu détaillé <span class="font-normal text-gray-400">(Markdown — page de l'événement)</span></label>
          <textarea id="content" rows="6" placeholder="Programme, déroulé, informations pratiques…&#10;&#10;## Au programme&#10;- Départ 7h&#10;- ..." class={inputClass}></textarea>
        </div>
        <div>
          <label for="image" class="block text-sm font-medium mb-1.5">Image (URL)</label>
          <input id="image" type="text" placeholder="https://…" class={inputClass} />
        </div>
        <div>
          <label for="gallery-folder" class="block text-sm font-medium mb-1.5">Galerie photo <span class="font-normal text-gray-400">(lien du dossier Google Drive partagé)</span></label>
          <input id="gallery-folder" type="text" placeholder="https://drive.google.com/drive/folders/…" class={inputClass} />
          <p class="mt-1 text-xs text-gray-400">Partagez le dossier en « Tout le monde avec le lien », puis collez son lien ici. Les photos s'afficheront dans la galerie de l'événement.</p>
        </div>
        <label class="flex items-center gap-2 text-sm">
          <input id="draft" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" />
          Brouillon (non publié)
        </label>
        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium px-5 py-2.5 text-sm transition-colors">Enregistrer</button>
          <button type="button" id="modal-cancel" class="rounded-lg border border-gray-200 dark:border-gray-700 px-5 py-2.5 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Annuler</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import type { EventItem } from '../../../utils/store';
    import { eventsData } from '../../../utils/db';
    import { can } from '../../../utils/auth';
    import { toast } from '../../../utils/toast';
    import { setupImageUpload } from '../../../utils/storage';
    import { extractFolderId } from '../../../utils/drive';

    const seedEl = document.getElementById('event-seed');
    const seed: EventItem[] = seedEl?.textContent ? JSON.parse(seedEl.textContent) : [];
    eventsData.seedIfEmpty(seed);
    setupImageUpload('image', 'events');

    const canManage = can('events.manage');
    const body = document.getElementById('events-body')!;
    const empty = document.getElementById('empty-state')!;
    const count = document.getElementById('event-count')!;
    const modal = document.getElementById('event-modal')!;
    const form = document.getElementById('event-form') as HTMLFormElement;
    const title = document.getElementById('modal-title')!;
    const f = (id: string) => document.getElementById(id) as HTMLInputElement;

    const searchInput = document.getElementById('event-search') as HTMLInputElement;
    const filterSelect = document.getElementById('event-filter') as HTMLSelectElement;

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    async function render() {
      const search = searchInput.value.trim().toLowerCase();
      const filter = filterSelect.value;
      const now = Date.now();
      const events = (await eventsData.list())
        .filter((ev) => {
          const upcoming = new Date(ev.date).valueOf() >= now;
          if (filter === 'upcoming' && !upcoming) return false;
          if (filter === 'past' && upcoming) return false;
          if (filter === 'published' && ev.draft) return false;
          if (filter === 'draft' && !ev.draft) return false;
          if (search && !ev.title.toLowerCase().includes(search) && !(ev.location ?? '').toLowerCase().includes(search) && !(ev.activity ?? '').toLowerCase().includes(search)) return false;
          return true;
        })
        .sort((a, b) => b.date.localeCompare(a.date));
      count.textContent = String(events.length);
      empty.classList.toggle('hidden', events.length > 0);

      body.innerHTML = events
        .map((ev) => {
          const date = new Date(ev.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' });
          const badge = ev.draft
            ? '<span class="inline-flex rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 px-2 py-0.5 text-xs">Brouillon</span>'
            : '<span class="inline-flex rounded-full bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 px-2 py-0.5 text-xs">Publié</span>';
          const actions = canManage
            ? `<button data-edit="${escape(ev.id)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30">Éditer</button>
               <button data-delete="${escape(ev.id)}" data-name="${escape(ev.title)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30">Supprimer</button>`
            : '<span class="text-xs text-gray-400">—</span>';
          return `
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/40">
              <td class="px-4 py-3 font-medium">${escape(ev.title)}</td>
              <td class="px-4 py-3 text-gray-500 dark:text-gray-400 whitespace-nowrap">${date}</td>
              <td class="px-4 py-3 text-gray-500 dark:text-gray-400">${escape(ev.location ?? '—')}</td>
              <td class="px-4 py-3">${badge}</td>
              <td class="px-4 py-3"><div class="flex items-center justify-end gap-2">${actions}</div></td>
            </tr>`;
        })
        .join('');
    }

    function openModal(ev?: EventItem) {
      title.textContent = ev ? 'Modifier l’événement' : 'Nouvel événement';
      f('event-id').value = ev?.id ?? '';
      f('title').value = ev?.title ?? '';
      f('date').value = ev ? ev.date.slice(0, 10) : new Date().toISOString().slice(0, 10);
      f('location').value = ev?.location ?? '';
      f('activity').value = ev?.activity ?? '';
      (document.getElementById('description') as HTMLTextAreaElement).value = ev?.description ?? '';
      (document.getElementById('content') as HTMLTextAreaElement).value = ev?.content ?? '';
      f('image').value = ev?.image ?? '';
      f('gallery-folder').value = ev?.galleryFolder ?? '';
      f('draft').checked = ev?.draft ?? false;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    searchInput.addEventListener('input', render);
    filterSelect.addEventListener('change', render);

    document.getElementById('add-event')?.addEventListener('click', () => openModal());
    document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    body.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const edit = target.closest<HTMLButtonElement>('[data-edit]');
      if (edit) {
        const ev = await eventsData.get(edit.dataset.edit!);
        if (ev) openModal(ev);
        return;
      }
      const del = target.closest<HTMLButtonElement>('[data-delete]');
      if (del && confirm(`Supprimer l'événement « ${del.dataset.name} » ?`)) {
        await eventsData.remove(del.dataset.delete!);
        await render();
        toast.success('Événement supprimé.');
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = {
        title: f('title').value.trim(),
        date: new Date(f('date').value || Date.now()).toISOString(),
        location: f('location').value.trim() || undefined,
        activity: f('activity').value.trim() || undefined,
        description: (document.getElementById('description') as HTMLTextAreaElement).value.trim() || undefined,
        content: (document.getElementById('content') as HTMLTextAreaElement).value.trim() || undefined,
        image: f('image').value.trim() || undefined,
        galleryFolder: extractFolderId(f('gallery-folder').value.trim()) || undefined,
        draft: f('draft').checked,
      };
      const id = f('event-id').value;
      if (id) await eventsData.update(id, data);
      else await eventsData.create(data);
      closeModal();
      await render();
      toast.success(id ? 'Événement mis à jour.' : 'Événement créé.');
    });

    render();
  </script>
</AdminLayout>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Messages" active="messages">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3 mb-6 text-sm">
    <div class="flex flex-wrap items-center gap-2">
      <button data-filter="all" class="filter-btn rounded-full px-3 py-1.5 bg-green-600 text-white">Tous (<span id="c-all">0</span>)</button>
      <button data-filter="new" class="filter-btn rounded-full px-3 py-1.5 bg-gray-100 dark:bg-gray-800">Nouveaux (<span id="c-new">0</span>)</button>
      <button data-filter="read" class="filter-btn rounded-full px-3 py-1.5 bg-gray-100 dark:bg-gray-800">Lus (<span id="c-read">0</span>)</button>
      <button data-filter="handled" class="filter-btn rounded-full px-3 py-1.5 bg-gray-100 dark:bg-gray-800">Traités (<span id="c-handled">0</span>)</button>
    </div>
    <div class="relative lg:w-64">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" /></svg>
      <input id="message-search" type="search" placeholder="Rechercher (nom, email, contenu)…" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 pl-9 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
    </div>
  </div>

  <div id="messages-list" class="space-y-3"></div>
  <p id="empty-state" class="hidden px-4 py-10 text-center text-gray-400">Aucun message dans cette catégorie.</p>

  <script>
    import { DEFAULT_MESSAGES } from '../../../utils/store';
    import type { MessageStatus } from '../../../utils/store';
    import { messagesData } from '../../../utils/db';
    import { can } from '../../../utils/auth';

    messagesData.seedIfEmpty(DEFAULT_MESSAGES);

    const canManage = can('messages.manage');
    const list = document.getElementById('messages-list')!;
    const empty = document.getElementById('empty-state')!;
    let filter: 'all' | MessageStatus = 'all';

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const STATUS: Record<MessageStatus, string> = {
      new: '<span class="inline-flex rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 px-2 py-0.5 text-xs">Nouveau</span>',
      read: '<span class="inline-flex rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 px-2 py-0.5 text-xs">Lu</span>',
      handled: '<span class="inline-flex rounded-full bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 px-2 py-0.5 text-xs">Traité</span>',
    };

    function refreshCounts(all: { status: MessageStatus }[]) {
      document.getElementById('c-all')!.textContent = String(all.length);
      document.getElementById('c-new')!.textContent = String(all.filter((m) => m.status === 'new').length);
      document.getElementById('c-read')!.textContent = String(all.filter((m) => m.status === 'read').length);
      document.getElementById('c-handled')!.textContent = String(all.filter((m) => m.status === 'handled').length);
    }

    const searchInput = document.getElementById('message-search') as HTMLInputElement;

    async function render() {
      const all = await messagesData.list();
      refreshCounts(all);
      const search = searchInput.value.trim().toLowerCase();
      const messages = all
        .filter((m) => filter === 'all' || m.status === filter)
        .filter((m) => !search || m.name.toLowerCase().includes(search) || m.email.toLowerCase().includes(search) || m.message.toLowerCase().includes(search))
        .sort((a, b) => b.date.localeCompare(a.date));
      empty.classList.toggle('hidden', messages.length > 0);

      list.innerHTML = messages
        .map((m) => {
          const date = new Date(m.date).toLocaleString('fr-FR', { dateStyle: 'medium', timeStyle: 'short' });
          const actions = canManage
            ? `<div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-gray-100 dark:border-gray-800">
                 ${m.status !== 'read' ? `<button data-status="read" data-id="${escape(m.id)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/30">Marquer lu</button>` : ''}
                 ${m.status !== 'handled' ? `<button data-status="handled" data-id="${escape(m.id)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30">Marquer traité</button>` : ''}
                 <a href="mailto:${escape(m.email)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800">Répondre</a>
                 <button data-delete="${escape(m.id)}" data-name="${escape(m.name)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30">Supprimer</button>
               </div>`
            : '';
          return `
            <article class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-5">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <p class="font-semibold">${escape(m.name)} <span class="ml-1 inline-flex rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs text-gray-500">${escape(m.service)}</span></p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">${escape(m.email)}${m.phone ? ` · ${escape(m.phone)}` : ''}</p>
                </div>
                <div class="text-right">
                  ${STATUS[m.status]}
                  <p class="text-xs text-gray-400 mt-1">${date}</p>
                </div>
              </div>
              <p class="mt-3 text-sm text-gray-700 dark:text-gray-300 whitespace-pre-line">${escape(m.message)}</p>
              ${actions}
            </article>`;
        })
        .join('');
    }

    document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        filter = btn.dataset.filter as typeof filter;
        document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
          const activeBtn = b === btn;
          b.classList.toggle('bg-green-600', activeBtn);
          b.classList.toggle('text-white', activeBtn);
          b.classList.toggle('bg-gray-100', !activeBtn);
          b.classList.toggle('dark:bg-gray-800', !activeBtn);
        });
        render();
      });
    });

    searchInput.addEventListener('input', render);

    list.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const statusBtn = target.closest<HTMLButtonElement>('[data-status]');
      if (statusBtn) {
        await messagesData.update(statusBtn.dataset.id!, { status: statusBtn.dataset.status as MessageStatus });
        await render();
        return;
      }
      const del = target.closest<HTMLButtonElement>('[data-delete]');
      if (del && confirm(`Supprimer le message de « ${del.dataset.name} » ?`)) {
        await messagesData.remove(del.dataset.delete!);
        await render();
      }
    });

    render();
  </script>
</AdminLayout>

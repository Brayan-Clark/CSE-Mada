---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { PERMISSIONS } from '../../../utils/store';

const permissionEntries = Object.entries(PERMISSIONS);
const inputClass =
  'w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent';
---

<AdminLayout title="Rôles & permissions" active="roles">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xl">
      Créez des rôles et cochez ce que chaque rôle a le droit de faire. Les utilisateurs reçoivent ensuite un rôle dans la page « Utilisateurs ».
    </p>
    <button id="add-role" class="inline-flex items-center gap-2 rounded-lg bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 text-sm font-medium transition-colors shrink-0">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
      Nouveau rôle
    </button>
  </div>

  <div id="roles-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>

  <!-- Modale rôle -->
  <div id="role-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-6 shadow-xl max-h-[90vh] overflow-y-auto">
      <h3 id="modal-title" class="text-lg font-bold mb-5">Nouveau rôle</h3>
      <form id="role-form" class="space-y-4">
        <input type="hidden" id="role-id" />
        <div>
          <label for="label" class="block text-sm font-medium mb-1.5">Nom du rôle *</label>
          <input id="label" type="text" required placeholder="ex: Modérateur" class={inputClass} />
        </div>
        <div>
          <label for="description" class="block text-sm font-medium mb-1.5">Description</label>
          <input id="description" type="text" placeholder="À quoi sert ce rôle ?" class={inputClass} />
        </div>

        <div>
          <p class="block text-sm font-medium mb-2">Permissions accordées</p>
          <div id="perms-box" class="space-y-2 rounded-lg border border-gray-200 dark:border-gray-700 p-3 max-h-56 overflow-y-auto">
            {permissionEntries.map(([key, label]) => (
              <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" class="perm-check h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" data-perm={key} />
                {label}
              </label>
            ))}
          </div>
          <p id="admin-note" class="hidden mt-2 text-xs text-amber-600 dark:text-amber-400">Le rôle Administrateur possède toujours toutes les permissions.</p>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium px-5 py-2.5 text-sm transition-colors">Enregistrer</button>
          <button type="button" id="modal-cancel" class="rounded-lg border border-gray-200 dark:border-gray-700 px-5 py-2.5 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Annuler</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import {
      seedRoles,
      PERMISSIONS, getRolePermissions, setRolePermissions, removeRoleFromMatrix,
      DEFAULT_ROLES, DEFAULT_USERS,
    } from '../../../utils/store';
    import type { RoleDef, User } from '../../../utils/store';
    import { rolesData, usersData } from '../../../utils/db';

    seedRoles();
    rolesData.seedIfEmpty(DEFAULT_ROLES);
    usersData.seedIfEmpty(DEFAULT_USERS);

    // En mode Supabase, les permissions vivent dans la colonne `permissions` de
    // la table roles ; en mode démo, dans la matrice locale (getRolePermissions).
    type RoleRow = RoleDef & { permissions?: string[] };
    const permsOf = (r: RoleRow) => r.permissions ?? getRolePermissions(r.id);

    const grid = document.getElementById('roles-grid')!;
    const modal = document.getElementById('role-modal')!;
    const form = document.getElementById('role-form') as HTMLFormElement;
    const title = document.getElementById('modal-title')!;
    const adminNote = document.getElementById('admin-note')!;
    const f = (id: string) => document.getElementById(id) as HTMLInputElement;

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const slugify = (s: string) =>
      s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'role';

    let usersCache: User[] = [];
    function usersCount(roleId: string) {
      return usersCache.filter((u) => u.role === roleId).length;
    }

    async function render() {
      const [roles, users] = await Promise.all([rolesData.list(), usersData.list()]);
      usersCache = users;
      grid.innerHTML = (roles as RoleRow[])
        .map((r) => {
          const perms = permsOf(r);
          const count = (r.id === 'admin' || r.id === 'superadmin') ? Object.keys(PERMISSIONS).length : perms.length;
          const sys = r.system
            ? '<span class="inline-flex rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 px-2 py-0.5 text-xs">Système</span>'
            : '';
          const del = r.system
            ? ''
            : `<button data-delete="${escape(r.id)}" data-label="${escape(r.label)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30">Supprimer</button>`;
          return `
            <article class="rounded-xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-5 flex flex-col">
              <div class="flex items-center justify-between gap-2">
                <h3 class="font-semibold">${escape(r.label)}</h3>
                ${sys}
              </div>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 flex-1">${escape(r.description ?? '')}</p>
              <p class="mt-3 text-xs text-gray-400">${count} permission(s) · ${usersCount(r.id)} utilisateur(s)</p>
              <div class="mt-4 flex gap-2 border-t border-gray-100 dark:border-gray-800 pt-3">
                <button data-edit="${escape(r.id)}" class="rounded-md px-2.5 py-1.5 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30">Modifier</button>
                ${del}
              </div>
            </article>`;
        })
        .join('');
    }

    function setChecks(perms: string[], disabled: boolean) {
      document.querySelectorAll<HTMLInputElement>('.perm-check').forEach((cb) => {
        cb.checked = disabled || perms.includes(cb.dataset.perm!);
        cb.disabled = disabled;
      });
    }

    function openModal(role?: RoleRow) {
      const isAdmin = role?.id === 'admin' || role?.id === 'superadmin';
      title.textContent = role ? 'Modifier le rôle' : 'Nouveau rôle';
      f('role-id').value = role?.id ?? '';
      f('label').value = role?.label ?? '';
      f('description').value = role?.description ?? '';
      setChecks(role ? permsOf(role) : [], isAdmin);
      adminNote.classList.toggle('hidden', !isAdmin);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.getElementById('add-role')?.addEventListener('click', () => openModal());
    document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    grid.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const edit = target.closest<HTMLButtonElement>('[data-edit]');
      if (edit) {
        const r = (await rolesData.get(edit.dataset.edit!)) as RoleRow | undefined;
        if (r) openModal(r);
        return;
      }
      const del = target.closest<HTMLButtonElement>('[data-delete]');
      if (del) {
        const id = del.dataset.delete!;
        if (usersCount(id) > 0) {
          alert(`Impossible : des utilisateurs ont encore le rôle « ${del.dataset.label} ». Réaffectez-les d'abord.`);
          return;
        }
        if (confirm(`Supprimer le rôle « ${del.dataset.label} » ?`)) {
          await rolesData.remove(id);
          removeRoleFromMatrix(id);
          await render();
        }
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const label = f('label').value.trim();
      if (!label) return;
      const editingId = f('role-id').value;
      const perms = Array.from(document.querySelectorAll<HTMLInputElement>('.perm-check'))
        .filter((cb) => cb.checked)
        .map((cb) => cb.dataset.perm!);
      const isAdmin = editingId === 'admin' || editingId === 'superadmin';

      if (editingId) {
        await rolesData.update(editingId, { label, description: f('description').value.trim(), ...(isAdmin ? {} : { permissions: perms }) } as Partial<RoleRow>);
        if (!isAdmin) setRolePermissions(editingId, perms);
      } else {
        // génère un id unique à partir du nom
        let id = slugify(label);
        const existing = new Set((await rolesData.list()).map((r) => r.id));
        while (existing.has(id)) id = `${id}-${Math.random().toString(36).slice(2, 5)}`;
        await rolesData.create({ id, label, description: f('description').value.trim(), permissions: perms } as RoleRow);
        setRolePermissions(id, perms);
      }
      closeModal();
      await render();
    });

    render();
  </script>
</AdminLayout>

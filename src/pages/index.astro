---
import Layout from '../layouts/Layout.astro';

// Fonction utilitaire pour tronquer le texte
const truncateText = (text, maxLength) => {
  if (!text) return '';
  return text.length > maxLength ? text.substring(0, maxLength) + '...' : text;
};

const base = import.meta.env.BASE_URL;

const features = [
  {
    title: 'Matériel de qualité',
    description: 'Découvrez notre sélection de matériel de camping haut de gamme pour toutes vos aventures en plein air.',
    icon: '🏕️',
  },
  {
    title: 'Services sur mesure',
    description: 'Des expériences de camping clés en main, de la randonnée guidée aux séjours en pleine nature.',
    icon: '🌟',
  },
  {
    title: 'Destinations uniques',
    description: 'Explorez les plus beaux sites de camping de Madagascar avec nos guides experts.',
    icon: '🗺️',
  },
];
---

<Layout title="Accueil - Camping Store & Event Madagascar" description="Votre partenaire pour des aventures en plein air inoubliables à Madagascar. Location de matériel et organisation d'événements de camping.">
  <div class="relative overflow-hidden">
    <!-- Hero Section avec image de fond -->
    <div class="relative min-h-[500px] flex items-center bg-cover bg-center bg-no-repeat bg-fixed dark:brightness-90" 
         style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1533575770077-052fa2c609fc?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center text-white">
          <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
            L'aventure vous attend à <span class="text-green-400 dark:text-green-300">Madagascar</span>
          </h1>
          <p class="mt-6 max-w-2xl mx-auto text-xl text-gray-100 dark:text-gray-200">
            Découvrez nos services de location de matériel de camping et d'organisation d'événements en pleine nature.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
            <a 
              href={`${base}/materiel`}
              class="px-6 py-4 rounded-md bg-green-600 hover:bg-green-700 text-white font-medium transition-colors text-lg dark:bg-green-700 dark:hover:bg-green-600"
            >
              Voir le matériel disponible
            </a>
            <a 
              href="#services" 
              class="px-6 py-4 rounded-md border-2 border-white text-white font-medium hover:bg-white/10 transition-colors text-lg dark:border-green-300 dark:text-green-100 dark:hover:bg-green-900/30"
            >
              Découvrir nos services
            </a>
          </div>
        </div>
      </div>
    </div>
    </div>

    <!-- Features Section -->
    <div id="features" class="py-16 bg-white dark:bg-gray-800">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <span class="inline-block px-3 py-1 text-sm font-semibold text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30 rounded-full mb-4">Nos Services</span>
          <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
            Votre aventure commence ici
          </h2>
          <p class="mt-4 max-w-2xl mx-auto text-gray-600 dark:text-gray-300">
            Découvrez notre gamme complète de services pour des expériences de camping inoubliables à Madagascar.
          </p>
        </div>
        <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {features.map((feature, index) => (
            <div key={index} class="bg-white dark:bg-gray-700 p-8 rounded-xl shadow-md border border-gray-100 dark:border-gray-600 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
              <div class="text-5xl mb-6">{feature.icon}</div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">{feature.title}</h3>
              <p class="text-gray-600 dark:text-gray-300">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-green-600 dark:bg-green-800 py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Prêt à vivre l'aventure ?
        </h2>
        <p class="mt-4 text-lg text-green-100 dark:text-green-200 max-w-2xl mx-auto">
          Réservez dès maintenant votre matériel ou votre séjour et vivez une expérience inoubliable dans les paysages magnifiques de Madagascar.
        </p>
        <div class="mt-8">
          <a href={`${base}/contact`} class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-green-700 bg-white hover:bg-green-50 dark:bg-green-100 dark:hover:bg-green-200">
            Contactez-nous
            <svg class="ml-3 -mr-1 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Gallery Section -->
    <div class="py-16 bg-gray-50 dark:bg-gray-800/80">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 text-sm font-semibold text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30 rounded-full mb-4">Galerie</span>
          <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
            Nos dernières aventures
          </h2>
          <p class="mt-4 max-w-2xl mx-auto text-gray-600 dark:text-gray-300">
            Découvrez en images nos expéditions et événements à travers Madagascar.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {(
            await Astro.glob('../content/events/*.md')
              .then(events => events
                .filter(event => !event.frontmatter.draft)
                .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date))
                .slice(0, 3)
              )
          ).map(event => (
            <a href={`${base}/events/${event.file.split('/').pop()?.replace(/\.md$/, '')?.replace('.', '')}`} class="block group">
              <div class="h-full rounded-xl overflow-hidden shadow-lg dark:shadow-gray-900/50 hover:shadow-xl transition-shadow duration-300 bg-white dark:bg-gray-700">
                <div class="overflow-hidden">
                  <img 
                    src={event.frontmatter.image || 'https://images.unsplash.com/photo-1515876305430-f06edab8282a?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'} 
                    alt={event.frontmatter.title} 
                    class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-105" />
                </div>
                <div class="p-6">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white" title={event.frontmatter.title}>
                      {truncateText(event.frontmatter.title, 30)}
                    </h3>
                    <span class="inline-block px-2 py-1 text-xs font-medium text-green-800 bg-green-100 rounded-full dark:bg-green-900/30 dark:text-green-300 whitespace-nowrap">
                      {new Date(event.frontmatter.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}
                    </span>
                  </div>
                  <p class="text-gray-600 dark:text-gray-300" title={event.frontmatter.description}>
                    {truncateText(event.frontmatter.description, 100)}
                  </p>
                  {event.frontmatter.location && (
                    <div class="mt-3 flex items-center text-sm text-gray-500 dark:text-gray-400">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      {event.frontmatter.location}
                    </div>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-green-700 dark:bg-green-900/90 py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1483728642387-6c3bdd6de93a?q=80&w=876&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')] bg-cover bg-center opacity-10 dark:opacity-5"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Prêt pour l'aventure ?
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-green-100 dark:text-green-200 text-lg">
          Réservez dès maintenant votre matériel ou votre séjour et vivez une expérience inoubliable dans les paysages magnifiques de Madagascar.
        </p>
        <div class="mt-8">
          <a 
            href={`${base}/contact`}
            class="inline-flex items-center px-8 py-3 border-2 border-transparent text-base font-medium rounded-md text-green-800 bg-white hover:bg-green-50 dark:bg-green-100 dark:hover:bg-green-200 transition-colors"
          >
            Réserver maintenant
            <svg class="ml-3 -mr-1 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
    </div>
  </div>
</Layout>

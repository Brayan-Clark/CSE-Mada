---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/url';
import { getCollection } from 'astro:content';
import { formatMGA } from '../utils/format';
import { DEFAULT_PRODUCTS, DEFAULT_REVIEWS, PRODUCT_CATEGORIES } from '../utils/store';
import { publishedReviewsHTML } from '../utils/reviews-render';

const base = import.meta.env.BASE_URL;

// --- Événements à venir (content collections) ---
const allEvents = (
  await getCollection('events', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const now = Date.now();
const upcoming = allEvents.filter((e) => e.data.date.valueOf() >= now);
const events = (upcoming.length ? upcoming : [...allEvents].reverse()).slice(0, 3);
const fmtEventDate = (d: Date) =>
  new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });

// --- Matériel en vedette (placeholder build, hydraté client) ---
const catName = (id: string) => PRODUCT_CATEGORIES.find((c) => c.id === id)?.name ?? id;
const featuredSeed = (DEFAULT_PRODUCTS.filter((p) => p.featured).length
  ? DEFAULT_PRODUCTS.filter((p) => p.featured)
  : DEFAULT_PRODUCTS
).slice(0, 4);

// --- Avis (placeholder build, hydraté client) ---
const reviewsPlaceholder = publishedReviewsHTML(DEFAULT_REVIEWS, 3);

const stats = [
  { value: '50+', label: 'Sorties organisées' },
  { value: '500+', label: 'Aventuriers accompagnés' },
  { value: '20', label: 'Destinations à Madagascar' },
  { value: '4.9/5', label: 'Satisfaction clients' },
];

const pillars = [
  {
    title: 'Guides locaux experts',
    text: 'Des connaisseurs du terrain malgache pour des aventures sûres et authentiques.',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    title: 'Matériel contrôlé',
    text: 'Équipement de qualité, vérifié avant chaque sortie. Vente et location.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Sans paiement en ligne',
    text: 'Vous commandez, nous vous rappelons pour confirmer livraison et règlement.',
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  },
  {
    title: '100% Madagascar',
    text: 'Une équipe locale, passionnée par la Grande Île et ses paysages préservés.',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  },
];
---

<Layout
  title="Accueil - Camping Store & Event Madagascar"
  description="Votre partenaire pour des aventures en plein air inoubliables à Madagascar : vente et location de matériel de camping, organisation d'événements et sorties guidées."
>
  <!-- ============================ HERO ============================ -->
  <section class="relative isolate overflow-hidden bg-green-950">
    <!-- Image de fond -->
    <img
      src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?q=80&w=1600&auto=format&fit=crop"
      alt=""
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      aria-hidden="true"
    />
    <!-- Voile dégradé vert -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-green-950/85 via-green-950/60 to-green-950/90"></div>
    <!-- Motif topographique -->
    <svg class="absolute inset-0 -z-10 h-full w-full text-white/[0.06]" aria-hidden="true">
      <defs>
        <pattern id="topo" width="120" height="120" patternUnits="userSpaceOnUse" patternTransform="scale(1.4)">
          <path d="M0 60 Q30 30 60 60 T120 60" fill="none" stroke="currentColor" stroke-width="1.2" />
          <path d="M0 90 Q30 60 60 90 T120 90" fill="none" stroke="currentColor" stroke-width="1.2" />
          <path d="M0 30 Q30 0 60 30 T120 30" fill="none" stroke="currentColor" stroke-width="1.2" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#topo)" />
    </svg>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-32 sm:pt-28 sm:pb-40">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-green-100 ring-1 ring-inset ring-white/20 backdrop-blur">
          <svg class="h-4 w-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          Madagascar · Aventures en plein air
        </span>

        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl">
          Partez à l'aventure,<br />
          <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">on s'occupe de tout.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-green-50/90">
          Vente et location de matériel de camping, sorties guidées et organisation d'événements
          dans les plus beaux paysages de la Grande Île.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={withBase('/materiel')}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-amber-500 px-7 py-3.5 text-base font-semibold text-green-950 shadow-lg shadow-amber-500/25 transition-transform hover:scale-[1.03] hover:bg-amber-400"
          >
            Explorer le matériel
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a
            href={withBase('/events')}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/10 px-7 py-3.5 text-base font-semibold text-white ring-1 ring-inset ring-white/30 backdrop-blur transition-colors hover:bg-white/20"
          >
            Voir les événements
          </a>
        </div>
      </div>
    </div>

    <!-- Silhouette de montagnes (transition vers la section suivante) -->
    <svg class="absolute bottom-0 left-0 w-full text-white dark:text-gray-900" viewBox="0 0 1440 140" fill="currentColor" preserveAspectRatio="none" aria-hidden="true">
      <path opacity="0.4" d="M0 90 L240 40 L480 95 L720 35 L960 90 L1200 45 L1440 90 L1440 140 L0 140 Z" />
      <path d="M0 120 L180 70 L360 110 L600 60 L840 115 L1080 70 L1320 110 L1440 75 L1440 140 L0 140 Z" />
    </svg>
  </section>

  <!-- ============================ STATS ============================ -->
  <section class="bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 -mt-6">
      <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-gray-100 dark:bg-gray-800 shadow-xl ring-1 ring-gray-100 dark:ring-gray-800 lg:grid-cols-4" data-reveal>
        {stats.map((s) => (
          <div class="bg-white dark:bg-gray-900 px-6 py-8 text-center">
            <p class="text-3xl font-extrabold text-green-700 dark:text-green-400 sm:text-4xl">{s.value}</p>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ OFFRES (bento) ============================ -->
  <section class="bg-white dark:bg-gray-900 py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl" data-reveal>
        <span class="text-sm font-semibold uppercase tracking-wider text-green-600 dark:text-green-400">Ce que nous faisons</span>
        <h2 class="mt-2 text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">Tout pour vivre le plein air</h2>
        <p class="mt-4 text-gray-600 dark:text-gray-300">De l'équipement à l'expédition : une seule équipe, locale, pour chaque étape de votre aventure.</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-reveal>
        <!-- Carte large : Boutique -->
        <a href={withBase('/materiel')} class="group relative overflow-hidden rounded-3xl bg-green-700 p-8 text-white md:col-span-2 lg:row-span-2 lg:flex lg:flex-col lg:justify-end min-h-[260px]">
          <img src="https://images.unsplash.com/photo-1563299796-17596ed6b017?q=80&w=1000&auto=format&fit=crop" alt="" class="absolute inset-0 h-full w-full object-cover opacity-30 transition-transform duration-700 group-hover:scale-105" aria-hidden="true" />
          <div class="absolute inset-0 bg-gradient-to-t from-green-950/90 via-green-900/40 to-transparent"></div>
          <div class="relative">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-500 text-green-950">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17M17 13v0m0 4a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            </span>
            <h3 class="mt-4 text-2xl font-bold">Boutique matériel</h3>
            <p class="mt-2 max-w-md text-green-50/90">Tentes, sacs de couchage, cuisine, randonnée… Des prix en Ariary, une commande simple sans paiement en ligne.</p>
            <span class="mt-4 inline-flex items-center gap-1.5 font-semibold text-amber-300">Découvrir la boutique
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </div>
        </a>

        <!-- Événements -->
        <a href={withBase('/events')} class="group rounded-3xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50 p-7 transition-all hover:-translate-y-1 hover:shadow-lg">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </span>
          <h3 class="mt-4 text-lg font-bold text-gray-900 dark:text-white">Événements & sorties</h3>
          <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-300">Randonnées, bivouacs et expéditions encadrées toute l'année.</p>
        </a>

        <!-- Location -->
        <a href={withBase('/materiel')} class="group rounded-3xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50 p-7 transition-all hover:-translate-y-1 hover:shadow-lg">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </span>
          <h3 class="mt-4 text-lg font-bold text-gray-900 dark:text-white">Location de matériel</h3>
          <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-300">Pour une sortie ponctuelle, louez sans vous ruiner.</p>
        </a>

        <!-- Services -->
        <a href={withBase('/services')} class="group rounded-3xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50 p-7 transition-all hover:-translate-y-1 hover:shadow-lg lg:col-span-2">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
          </span>
          <h3 class="mt-4 text-lg font-bold text-gray-900 dark:text-white">Services sur mesure</h3>
          <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-300">Organisation d'événements clés en main, team building, séjours personnalisés.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================ MATÉRIEL EN VEDETTE ============================ -->
  <section class="bg-gray-50 dark:bg-gray-800/40 py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4" data-reveal>
        <div class="max-w-xl">
          <span class="text-sm font-semibold uppercase tracking-wider text-green-600 dark:text-green-400">Boutique</span>
          <h2 class="mt-2 text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">Notre matériel en vedette</h2>
        </div>
        <a href={withBase('/materiel')} class="inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">
          Tout voir
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>

      <div id="featured-grid" class="mt-10 grid grid-cols-2 gap-5 lg:grid-cols-4" data-reveal>
        {featuredSeed.map((p) => (
          <a href={withBase('/materiel')} class="group block overflow-hidden rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
            <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-700">
              {p.image && <img src={p.image} alt={p.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />}
            </div>
            <div class="p-4">
              <p class="text-xs text-gray-400">{catName(p.category)}</p>
              <h3 class="mt-0.5 font-semibold text-gray-900 dark:text-white line-clamp-1">{p.name}</h3>
              <p class="mt-1 font-bold text-green-700 dark:text-green-400">{formatMGA(p.price)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ ÉVÉNEMENTS À VENIR ============================ -->
  <section id="home-events" class:list={["bg-white dark:bg-gray-900 py-20", { hidden: events.length === 0 }]}>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4" data-reveal>
        <div class="max-w-xl">
          <span class="text-sm font-semibold uppercase tracking-wider text-green-600 dark:text-green-400">Agenda</span>
          <h2 class="mt-2 text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">Nos prochaines aventures</h2>
        </div>
        <a href={withBase('/events')} class="inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">
          Tout l'agenda
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>

      <div id="home-events-grid" class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal>
        {events.map((event) => (
          <a href={withBase(`/events/${event.slug}`)} class="group flex flex-col overflow-hidden rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
            <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-700">
              <img
                src={event.data.image ? `${base}/${event.data.image}` : 'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?q=80&w=800&auto=format&fit=crop'}
                alt={event.data.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-white/95 dark:bg-gray-900/95 px-3 py-1 text-xs font-semibold text-green-700 dark:text-green-400 shadow">
                {fmtEventDate(event.data.date)}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-5">
              <h3 class="font-bold text-gray-900 dark:text-white line-clamp-2">{event.data.title}</h3>
              {event.data.description && <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-300 line-clamp-2">{event.data.description}</p>}
              {event.data.location && (
                <p class="mt-3 inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
                  <svg class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  {event.data.location}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ NOS ENGAGEMENTS ============================ -->
  <section class="relative overflow-hidden bg-green-800 py-20">
    <svg class="absolute inset-0 h-full w-full text-white/[0.05]" aria-hidden="true"><rect width="100%" height="100%" fill="url(#topo)" /></svg>
    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl" data-reveal>
        <span class="text-sm font-semibold uppercase tracking-wider text-amber-300">Pourquoi nous</span>
        <h2 class="mt-2 text-3xl font-extrabold text-white sm:text-4xl">Une équipe en qui avoir confiance</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
        {pillars.map((p) => (
          <div class="rounded-2xl bg-white/10 p-6 ring-1 ring-inset ring-white/15 backdrop-blur">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-amber-500 text-green-950">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={p.icon} /></svg>
            </span>
            <h3 class="mt-4 font-bold text-white">{p.title}</h3>
            <p class="mt-1.5 text-sm text-green-50/80">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ TÉMOIGNAGES ============================ -->
  <section class="bg-white dark:bg-gray-900 py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="text-sm font-semibold uppercase tracking-wider text-green-600 dark:text-green-400">Ils nous ont fait confiance</span>
        <h2 class="mt-2 text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">Des aventures qui marquent</h2>
      </div>
      <div id="home-reviews" class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal set:html={reviewsPlaceholder}></div>
      <div class="mt-10 text-center" data-reveal>
        <a href={withBase('/temoignages')} class="inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">
          Lire tous les témoignages
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================ CTA FINAL ============================ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-green-700 to-green-900 py-20">
    <svg class="absolute inset-0 h-full w-full text-white/[0.06]" aria-hidden="true"><rect width="100%" height="100%" fill="url(#topo)" /></svg>
    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="mx-auto max-w-2xl text-3xl font-extrabold text-white sm:text-4xl">Prêt à vivre la prochaine aventure ?</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-green-50/90">Commandez votre matériel ou parlez-nous de votre projet : nous vous recontactons rapidement.</p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <a href={withBase('/materiel')} class="inline-flex items-center justify-center gap-2 rounded-xl bg-amber-500 px-7 py-3.5 font-semibold text-green-950 shadow-lg shadow-amber-500/25 transition-transform hover:scale-[1.03] hover:bg-amber-400">
          Commander du matériel
        </a>
        <a href={withBase('/contact')} class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/10 px-7 py-3.5 font-semibold text-white ring-1 ring-inset ring-white/30 backdrop-blur transition-colors hover:bg-white/20">
          Nous contacter
        </a>
      </div>
    </div>
  </section>

  <!-- Animations d'apparition -->
  <style>
    @media (prefers-reduced-motion: no-preference) {
      .reveal-init { opacity: 0; transform: translateY(26px); }
      .reveal-in { animation: revealUp 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards; }
      @keyframes revealUp { to { opacity: 1; transform: translateY(0); } }
    }
  </style>

  <script>
    import { productsData, reviewsData, eventsData } from '../utils/db';
    import { DEFAULT_PRODUCTS, DEFAULT_REVIEWS, PRODUCT_CATEGORIES } from '../utils/store';
    import { formatMGA } from '../utils/format';
    import { publishedReviewsHTML } from '../utils/reviews-render';
    import { withBase } from '../utils/url';

    // --- Apparition au scroll (le contenu reste visible si JS/motion off) ---
    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      const els = Array.from(document.querySelectorAll('[data-reveal]'));
      els.forEach((el) => el.classList.add('reveal-init'));
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('reveal-in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    }

    const esc = (s: string) =>
      String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const catName = (id: string) => PRODUCT_CATEGORIES.find((c) => c.id === id)?.name ?? id;

    // --- Matériel en vedette (live si données disponibles) ---
    productsData.seedIfEmpty(DEFAULT_PRODUCTS);
    const grid = document.getElementById('featured-grid');
    if (grid) {
      const all = await productsData.list();
      const featured = (all.filter((p) => p.featured).length ? all.filter((p) => p.featured) : all).slice(0, 4);
      if (featured.length) {
        grid.innerHTML = featured.map((p) => {
          const img = p.image
            ? `<img src="${esc(p.image)}" alt="${esc(p.name)}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />`
            : '';
          return `
            <a href="${withBase('/materiel')}" class="group block overflow-hidden rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
              <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-700">${img}</div>
              <div class="p-4">
                <p class="text-xs text-gray-400">${esc(catName(p.category))}</p>
                <h3 class="mt-0.5 font-semibold text-gray-900 dark:text-white line-clamp-1">${esc(p.name)}</h3>
                <p class="mt-1 font-bold text-green-700 dark:text-green-400">${formatMGA(p.price)}</p>
              </div>
            </a>`;
        }).join('');
      }
    }

    // --- Événements à venir (règle base-ou-static) ---
    // Si la base contient des événements, on les affiche (et on pointe vers la
    // belle page détail /events/detail) ; sinon on garde les cartes MDX rendues
    // au build (qui pointent vers /events/<slug>).
    const eventsSection = document.getElementById('home-events');
    const eventsGrid = document.getElementById('home-events-grid');
    if (eventsGrid && eventsSection) {
      const now = Date.now();
      const all = (await eventsData.list()).filter((e) => !e.draft);
      const upcoming = all.filter((e) => new Date(e.date).valueOf() >= now)
        .sort((a, b) => a.date.localeCompare(b.date));
      const past = all.filter((e) => new Date(e.date).valueOf() < now)
        .sort((a, b) => b.date.localeCompare(a.date));
      const list = (upcoming.length ? upcoming : past).slice(0, 3);
      if (list.length) {
        const fmt = (iso: string) => new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
        eventsGrid.innerHTML = list.map((e) => {
          const cover = e.image ? withBase(e.image) : 'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?q=80&w=800&auto=format&fit=crop';
          const loc = e.location
            ? `<p class="mt-3 inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400"><svg class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>${esc(e.location)}</p>`
            : '';
          const desc = e.description ? `<p class="mt-1.5 text-sm text-gray-600 dark:text-gray-300 line-clamp-2">${esc(e.description)}</p>` : '';
          return `
            <a href="${withBase(`/events/detail?id=${encodeURIComponent(e.id)}`)}" class="group flex flex-col overflow-hidden rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
              <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-700">
                <img src="${esc(cover)}" alt="${esc(e.title)}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-white/95 dark:bg-gray-900/95 px-3 py-1 text-xs font-semibold text-green-700 dark:text-green-400 shadow">${fmt(e.date)}</span>
              </div>
              <div class="flex flex-1 flex-col p-5">
                <h3 class="font-bold text-gray-900 dark:text-white line-clamp-2">${esc(e.title)}</h3>
                ${desc}${loc}
              </div>
            </a>`;
        }).join('');
        eventsSection.classList.remove('hidden');
      }
    }

    // --- Témoignages (live si données disponibles) ---
    reviewsData.seedIfEmpty(DEFAULT_REVIEWS);
    const reviewsGrid = document.getElementById('home-reviews');
    if (reviewsGrid) {
      const reviews = (await reviewsData.list()).filter((r) => r.status === 'published').slice(0, 3);
      if (reviews.length) reviewsGrid.innerHTML = publishedReviewsHTML(reviews, 3);
    }
  </script>
</Layout>

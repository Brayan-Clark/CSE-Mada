---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/url';
import { DEFAULT_REVIEWS } from '../utils/store';
import { publishedReviewsHTML } from '../utils/reviews-render';

// Placeholder rendu au build (mêmes données que la section avis de Services).
// Hydraté côté client : données Supabase si connecté, sinon données locales.
const placeholder = publishedReviewsHTML(DEFAULT_REVIEWS);

const stats = [
  { id: 1, name: 'Voyageurs satisfaits', value: '98%' },
  { id: 2, name: 'Expéditions réussies', value: '250+' },
  { id: 3, name: 'Années d\'expérience', value: '10+' },
  { id: 4, name: 'Avis 5 étoiles', value: '95%' },
];
---

<Layout title="Témoignages - Camping Store & Event Madagascar" description="Découvrez les avis de nos voyageurs et leurs expériences inoubliables avec CSEM à Madagascar.">
  <!-- Hero Section -->
  <div class="relative bg-gray-900 overflow-hidden">
    <div class="absolute inset-0">
      <img class="w-full h-full object-cover opacity-40" 
           src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?q=80&w=1000&auto=format&fit=crop&ixlib=rb-4.0.3&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
           alt="Témoignages"
           loading="lazy">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-gray-900 mix-blend-multiply"></div>
    </div>
    <div class="relative max-w-7xl mx-auto py-24 px-4 sm:py-32 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">Témoignages</h1>
      <p class="mt-6 text-xl text-gray-300 max-w-3xl">Découvrez ce que nos voyageurs disent de leur expérience avec CSEM.</p>
    </div>
  </div>

  <!-- Stats Section -->
  <div class="bg-white dark:bg-gray-900 py-12 sm:py-16 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <dl class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {stats.map((stat) => (
          <div key={stat.id} class="flex flex-col items-center">
            <dt class="text-4xl font-bold tracking-tight text-green-600 dark:text-green-400">{stat.value}</dt>
            <dd class="mt-2 text-base text-gray-600 dark:text-gray-400 text-center">{stat.name}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- Testimonials Grid -->
  <div class="bg-gray-50 dark:bg-gray-800 py-16 sm:py-24 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
          Ce que disent nos voyageurs
        </h2>
        <p class="mt-4 max-w-2xl text-xl text-gray-600 dark:text-gray-300 mx-auto">
          Des expériences authentiques, des souvenirs inoubliables
        </p>
      </div>

      <div id="testimonials-grid" class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3" set:html={placeholder}></div>
      <p id="testimonials-empty" class="hidden text-center text-gray-500 dark:text-gray-400 mt-12">Aucun témoignage publié pour le moment.</p>
    </div>
  </div>

  <!-- Video Testimonials -->
  <div class="bg-white dark:bg-gray-900 py-16 sm:py-24 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
          Expériences en vidéo
        </h2>
        <p class="mt-4 max-w-2xl text-xl text-gray-600 dark:text-gray-300 mx-auto">
          Découvrez les aventures de nos voyageurs
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <div class="aspect-w-16 aspect-h-9">
          <div class="rounded-lg overflow-hidden shadow-xl">
            <div class="relative pb-[56.25%] bg-gray-200 dark:bg-gray-800">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center p-4">
                  <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Vidéo de témoignage à venir</p>
                </div>
              </div>
            </div>
            <div class="p-4 bg-white dark:bg-gray-800">
              <h3 class="font-medium text-gray-900 dark:text-white">Aventure à Madagascar</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">Témoignage vidéo</p>
            </div>
          </div>
        </div>
        
        <div class="aspect-w-16 aspect-h-9">
          <div class="rounded-lg overflow-hidden shadow-xl">
            <div class="relative pb-[56.25%] bg-gray-200 dark:bg-gray-800">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center p-4">
                  <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Vidéo de témoignage à venir</p>
                </div>
              </div>
            </div>
            <div class="p-4 bg-white dark:bg-gray-800">
              <h3 class="font-medium text-gray-900 dark:text-white">Randonnée dans les Tsingy</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">Témoignage vidéo</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-green-700">
    <div class="max-w-4xl mx-auto py-16 px-4 sm:px-6 sm:py-20 lg:px-8 lg:flex lg:items-center lg:justify-between">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        <span class="block">Prêt à vivre votre propre aventure ?</span>
        <span class="block text-green-100">Rejoignez nos voyageurs satisfaits.</span>
      </h2>
      <div class="mt-8 flex lg:mt-0 lg:flex-shrink-0">
        <div class="inline-flex rounded-md shadow">
          <a href={withBase('/contact')} class="inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-green-600 bg-white hover:bg-green-50">
            Contactez-nous
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { reviewsData } from '../utils/db';
    import { DEFAULT_REVIEWS } from '../utils/store';
    import { reviewCardHTML } from '../utils/reviews-render';

    const grid = document.getElementById('testimonials-grid');
    const empty = document.getElementById('testimonials-empty');
    (async () => {
      reviewsData.seedIfEmpty(DEFAULT_REVIEWS);
      const reviews = (await reviewsData.list()).filter((r) => r.status === 'published');
      if (!grid) return;
      if (reviews.length) {
        grid.innerHTML = reviews.map(reviewCardHTML).join('');
        empty?.classList.add('hidden');
      } else {
        grid.innerHTML = '';
        empty?.classList.remove('hidden');
      }
    })();
  </script>
</Layout>

<style>
  /* Animation pour les cartes de témoignages */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .testimonial-card {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  /* Délais d'animation pour chaque carte */
  .testimonial-card:nth-child(1) { animation-delay: 0.1s; }
  .testimonial-card:nth-child(2) { animation-delay: 0.2s; }
  .testimonial-card:nth-child(3) { animation-delay: 0.3s; }
  .testimonial-card:nth-child(4) { animation-delay: 0.4s; }
  .testimonial-card:nth-child(5) { animation-delay: 0.5s; }
  .testimonial-card:nth-child(6) { animation-delay: 0.6s; }

  /* Style pour les citations */
  blockquote {
    position: relative;
    padding-left: 1rem;
    border-left: 3px solid #10b981;
  }

  /* Style pour les vidéos */
  .aspect-w-16 {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
  }

  .aspect-w-16 iframe,
  .aspect-w-16 video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

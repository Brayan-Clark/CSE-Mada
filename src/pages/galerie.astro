---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/url';
---

<Layout title="Galeries photo des événements" description="Revivez nos événements en images : randonnées, team building, sorties en groupe et événements privés à Madagascar.">
  <!-- Hero -->
  <div class="relative bg-gray-900 overflow-hidden">
    <img class="absolute inset-0 w-full h-full object-cover opacity-40" src="https://images.unsplash.com/photo-1414016642750-7fdd78dc33d9?q=80&w=1000&auto=format&fit=crop" alt="Galeries photo" />
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/60 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto py-16 px-4 sm:py-20 sm:px-6 lg:px-8">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-green-600/90 text-white px-3 py-1 text-xs font-semibold">📸 Galeries</span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl">Nos événements en images</h1>
      <p class="mt-3 max-w-2xl text-lg text-gray-200">Chaque événement a sa galerie photo. Cliquez pour revivre les meilleurs moments.</p>
    </div>
  </div>

  <div class="bg-gray-50 dark:bg-gray-800 py-10 min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p id="gx-loading" class="text-center text-gray-500 dark:text-gray-400 py-16">Chargement des galeries…</p>
      <div id="gx-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
      <div id="gx-empty" class="hidden text-center py-16">
        <p class="text-4xl mb-3">📷</p>
        <p class="text-gray-500 dark:text-gray-400">Aucune galerie pour le moment.</p>
        <a href={withBase('/events')} class="mt-4 inline-flex items-center gap-1.5 font-semibold text-green-700 dark:text-green-400 hover:underline">Voir les événements →</a>
      </div>
    </div>
  </div>

  <script>
    import { eventsData } from '../utils/db';
    import { listDriveImages, driveThumb, isDriveEnabled } from '../utils/drive';
    import { withBase } from '../utils/url';

    const $ = (id: string) => document.getElementById(id)!;
    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const events = (await eventsData.list())
      .filter((e) => !e.draft && e.galleryFolder)
      .sort((a, b) => b.date.localeCompare(a.date));

    $('gx-loading').classList.add('hidden');

    if (events.length === 0 || !isDriveEnabled) {
      $('gx-empty').classList.remove('hidden');
    } else {
      // Couverture = première photo de chaque dossier Drive.
      const cards = await Promise.all(events.map(async (ev) => {
        const imgs = await listDriveImages(ev.galleryFolder!);
        return { ev, cover: imgs[0], count: imgs.length };
      }));
      const withPhotos = cards.filter((c) => c.count > 0);
      if (withPhotos.length === 0) {
        $('gx-empty').classList.remove('hidden');
      } else {
        $('gx-grid').innerHTML = withPhotos.map(({ ev, cover, count }) => {
          const date = new Date(ev.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
          const href = withBase(`/events/gallery?id=${encodeURIComponent(ev.id)}`);
          return `
            <a href="${href}" class="group block rounded-2xl overflow-hidden bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-lg transition-shadow">
              <div class="relative aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-800">
                <img src="${driveThumb(cover.id, 800)}" alt="${escape(ev.title)}" loading="lazy" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" />
                <span class="absolute bottom-2 right-2 rounded-full bg-black/60 text-white text-xs px-2 py-0.5">${count} photo${count > 1 ? 's' : ''}</span>
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-green-700 dark:group-hover:text-green-400 transition-colors">${escape(ev.title)}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">${date}</p>
              </div>
            </a>`;
        }).join('');
      }
    }
  </script>
</Layout>
